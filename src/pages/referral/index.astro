---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Provider Referrals">
  <div class="container" style="padding: var(--spacing-6) 0; max-width: 800px; text-align: center;">
    <h1 style="color: var(--color-primary-blue); font-size: 2.5rem; margin-bottom: var(--spacing-4);">Provider/Partner Referrals</h1>
    <p style="font-size: 1.1rem; margin-bottom: var(--spacing-6); color: var(--color-text-muted);">
      Securely refer a patient or client to The WEL Foundation.
    </p>

    <div class="card" style="text-align: left; margin-bottom: var(--spacing-6);">
      <h2 style="margin-bottom: var(--spacing-3);">Referral Requirements</h2>
      <p style="margin-bottom: var(--spacing-4);">For an expedited processing time, please have the following client documentation ready to upload via our secure intake channel:</p>
      <ul style="margin-bottom: var(--spacing-4); padding-left: var(--spacing-4);">
        <li style="margin-bottom: var(--spacing-2);">Client's demographic and contact profiles.</li>
        <li style="margin-bottom: var(--spacing-2);">Current medical or psychiatric assessments justifying the program selection.</li>
        <li style="margin-bottom: var(--spacing-2);">Consent-to-release forms (if sending behavioral records).</li>
      </ul>
      <div style="text-align: center; margin-top: var(--spacing-6);">
        <a href="/referral/start/" class="btn" style="padding: 1rem 2rem; font-size: 1.1rem; background-color: var(--color-accent-gold); color: var(--color-primary-blue);">Submit Referral</a>
      </div>
    </div>
  </div>
</Layout>
