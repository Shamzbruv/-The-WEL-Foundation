---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Staff Login">
  <div class="login-wrapper">
    <!-- Decorative background elements -->
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
    
    <div class="login-container reveal-visible">
      <div class="login-card">
        <div class="brand-header">
           <div class="logo-circle">
             <i class="fa-solid fa-shield-halved"></i>
           </div>
           <h2>The WEL Foundation</h2>
        </div>
        
        <div class="login-header">
          <h1>Staff Access</h1>
          <p>Secure portal for authorized personnel</p>
        </div>
        
        <form id="login-form" class="login-form">
          <div class="form-group">
            <label for="email">Work Email</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-envelope input-icon"></i>
              <input type="email" id="email" placeholder="name@weempowerleadership.com" required autocomplete="email" />
            </div>
          </div>
          
          <div class="form-group">
            <label for="password">Password</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-lock input-icon"></i>
              <input type="password" id="password" placeholder="••••••••" required autocomplete="current-password" />
            </div>
          </div>
          
          <div id="login-error" class="error-message" style="display: none;">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>Invalid login credentials. Please try again.</span>
          </div>
          
          <button type="submit" class="btn btn-login" id="submit-btn">
            <span class="btn-text">Secure Sign In</span>
            <i class="fa-solid fa-arrow-right btn-icon"></i>
            <span class="loader" style="display: none;"><i class="fa-solid fa-circle-notch fa-spin"></i></span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <style>
    /* Prevent header/footer distractions for a focused login experience */
    :global(#site-header), :global(.site-footer) {
      display: none !important;
    }

    :global(body) {
      background-color: #F8FAFC !important;
      margin: 0;
    }

    .login-wrapper {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #F8FAFC 0%, #E2E8F0 100%);
      overflow: hidden;
      padding: var(--spacing-4);
    }

    .bg-shape {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      z-index: 0;
      opacity: 0.6;
      animation: float 10s infinite ease-in-out alternate;
    }

    .shape-1 {
      width: 50vw;
      height: 50vw;
      max-width: 600px;
      max-height: 600px;
      background: rgba(15, 23, 42, 0.08); /* Primary navy soft shadow */
      top: -10%;
      left: -10%;
    }

    .shape-2 {
      width: 60vw;
      height: 60vw;
      max-width: 700px;
      max-height: 700px;
      background: rgba(212, 175, 55, 0.08); /* Gold accent soft shadow */
      bottom: -15%;
      right: -10%;
      animation-delay: -5s;
    }

    @keyframes float {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(40px, 60px) scale(1.05); }
    }

    .login-container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 440px;
      animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes slideUpFade {
      0% { opacity: 0; transform: translateY(30px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .login-card {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: saturate(180%) blur(24px);
      -webkit-backdrop-filter: saturate(180%) blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.8);
      border-radius: var(--radius-2xl);
      padding: 3rem 2.5rem;
      box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.15), 0 0 0 1px rgba(255,255,255,0.5) inset;
    }

    .brand-header {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .logo-circle {
      width: 36px;
      height: 36px;
      background-color: var(--color-primary-navy);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-circle i {
      color: var(--color-accent-gold-muted);
      font-size: 14px;
    }

    .brand-header h2 {
      font-family: var(--font-family-heading);
      color: var(--color-primary-navy);
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
    }

    .login-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .login-header h1 {
      font-family: var(--font-family-heading);
      font-size: 1.8rem;
      color: var(--color-text-primary);
      margin: 0 0 0.5rem 0;
      letter-spacing: -0.02em;
    }

    .login-header p {
      color: var(--color-text-secondary);
      font-size: 0.95rem;
      margin: 0;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-size: 0.925rem;
      font-weight: 600;
      color: var(--color-text-primary);
    }

    .input-wrapper {
      position: relative;
    }

    .input-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94A3B8;
      font-size: 1rem;
      transition: color 0.3s ease;
      pointer-events: none;
    }

    .login-form input {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 2.75rem;
      border: 2px solid #E2E8F0;
      border-radius: var(--radius-md);
      background-color: #F8FAFC;
      font-family: inherit;
      font-size: 1rem;
      color: var(--color-text-primary);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-sizing: border-box;
    }

    .login-form input:hover {
      border-color: #CBD5E1;
    }

    .login-form input:focus {
      outline: none;
      border-color: var(--color-primary-navy);
      background-color: #ffffff;
      box-shadow: 0 0 0 4px rgba(15, 23, 42, 0.06);
    }

    .login-form input:focus + .input-icon,
    .login-form input:not(:placeholder-shown) + .input-icon {
      color: var(--color-primary-navy);
    }

    .btn-login {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      padding: 1rem;
      margin-top: 2rem;
      font-size: 1rem;
      font-weight: 600;
      color: white;
      background: linear-gradient(135deg, var(--color-primary-navy) 0%, #1E293B 100%);
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(15, 23, 42, 0.2);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(15, 23, 42, 0.3);
    }

    .btn-login:active {
      transform: translateY(0);
    }

    .error-message {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background-color: #FEF2F2;
      color: #DC2626;
      padding: 1rem;
      border-radius: var(--radius-md);
      font-size: 0.9rem;
      margin-top: 1.5rem;
      border: 1px solid #FECACA;
      animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    }

    .error-message i {
      margin-top: 2px;
    }

    @keyframes shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }
    
    @media (max-width: 480px) {
      .login-card {
        padding: 2.5rem 1.75rem;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { createClient } from '@supabase/supabase-js';

    // Public anon key only.
    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL || 'YOUR_SUPABASE_URL',
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'YOUR_ANON_KEY'
    );

    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('login-form');
      if(form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = document.getElementById('email').value;
          const password = document.getElementById('password').value;
          const errBox = document.getElementById('login-error');
          const btnText = document.querySelector('.btn-text');
          const btnIcon = document.querySelector('.btn-icon');
          const loader = document.querySelector('.loader');

          // Reset UI
          errBox.style.display = 'none';
          btnText.style.display = 'none';
          btnIcon.style.display = 'none';
          loader.style.display = 'inline-block';

          const { data, error } = await supabase.auth.signInWithPassword({ email, password });
          
          if (error) {
            errBox.querySelector('span').innerText = 'Invalid login credentials. Please try again.';
            errBox.style.display = 'flex';
            // Reset button
            btnText.style.display = 'block';
            btnIcon.style.display = 'inline-block';
            loader.style.display = 'none';
          } else {
            // Redirect to dashboard on success
            window.location.href = '/staff/';
          }
        });
      }

      // Auto-redirect if already logged in
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (session) {
           window.location.href = '/staff/';
        }
      });
    });
  </script>
</Layout>
