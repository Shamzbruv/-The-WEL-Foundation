---
import StaffPortalLayout from '../../layouts/StaffPortalLayout.astro';
---
<StaffPortalLayout title="My Workspace">
    <div style="display: grid; grid-template-columns: 3fr 1fr; gap: 2rem;">
        <div class="card">
            <h2>Active Assignments</h2>
            <p style="color: #64748b; font-size: 0.9rem; margin-top: -0.5rem; margin-bottom: 1.5rem;">Submissions currently assigned directly to you.</p>
            <div class="table-responsive">
<table class="portal-table" id="my-workspace-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Applicant</th>
                        <th>Type</th>
                        <th>SLA Deadline</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="6">Loading workspace...</td></tr>
                </tbody>
            </table>
</div>
        </div>

        <div class="card">
            <h2>My Notifications</h2>
            <div id="notifications-feed" style="margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                <p>Loading...</p>
            </div>
        </div>
    </div>
    
    <script>
      import { createClient } from '@supabase/supabase-js';
      if(!(window as any).supabase) { (window as any).supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL || "https://placeholder.supabase.co", import.meta.env.PUBLIC_SUPABASE_ANON_KEY || "public-anon-key"); } const supabase = (window as any).supabase;

      document.addEventListener('astro:page-load', async () => {
          const { data: { session } } = await supabase.auth.getSession();
          if (!session) {
             window.location.href = '/staff/login/';
             return;
          }
          
          const tbody = document.querySelector('#my-workspace-table tbody');
          if (tbody) {
            // Fetch items assigned to me that are not completed, explicitly selecting fields
            const { data, error } = await supabase
                .from('submissions')
                .select('id, created_at, due_at, type, status, internal_priority, submitted_by_name, submitted_by_email')
                .eq('assigned_to', session.user.id)
                .neq('status', 'Completed')
                .order('due_at', { ascending: true });

            if (error) {
                tbody.innerHTML = `<tr><td colspan="6" style="color:red;">Error: ${error.message}</td></tr>`;
            } else if (!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding: 2rem; color: #94a3b8;">No active assignments. Great job!</td></tr>`;
            } else {
                tbody.innerHTML = '';
                data.forEach((sub: any) => {
                    const row = document.createElement('tr');
                    const sDate = new Date(sub.created_at).toLocaleDateString();
                    const dueStr = sub.due_at ? new Date(sub.due_at).toLocaleDateString() : 'N/A';

                    // Col: Date
                    const tdDate = document.createElement('td');
                    tdDate.textContent = sDate;

                    // Col: Applicant — XSS-safe
                    const tdApplicant = document.createElement('td');
                    const nameStrong = document.createElement('strong');
                    nameStrong.textContent = sub.submitted_by_name;
                    const emailSpan = document.createElement('span');
                    emailSpan.style.display = 'block';
                    emailSpan.style.color = '#64748b';
                    emailSpan.style.fontSize = '0.85rem';
                    emailSpan.textContent = sub.submitted_by_email;
                    tdApplicant.appendChild(nameStrong);
                    tdApplicant.appendChild(emailSpan);

                    // Col: Type + Priority (internal enum values — safe)
                    const tdType = document.createElement('td');
                    const typeText = document.createElement('span');
                    typeText.textContent = (sub.type || '').toUpperCase();
                    const prioritySmall = document.createElement('small');
                    prioritySmall.style.display = 'block';
                    prioritySmall.style.color = 'gray';
                    prioritySmall.textContent = 'Priority: ' + (sub.internal_priority || 'Normal');
                    tdType.appendChild(typeText);
                    tdType.appendChild(prioritySmall);

                    // Col: SLA Due
                    const tdDue = document.createElement('td');
                    const dueStrong = document.createElement('strong');
                    dueStrong.textContent = dueStr;
                    tdDue.appendChild(dueStrong);

                    // Col: Status pill (internal enum value — safe)
                    const tdStatus = document.createElement('td');
                    const pill = document.createElement('span');
                    pill.className = `status-pill status-${(sub.status || '').replace(/\s+/g, '')}`;
                    pill.textContent = sub.status;
                    tdStatus.appendChild(pill);

                    // Col: Action link
                    const tdAction = document.createElement('td');
                    const link = document.createElement('a');
                    link.href = `/staff/submissions/detail?id=${sub.id}`;
                    link.className = 'btn-primary';
                    link.style.textDecoration = 'none';
                    link.style.display = 'inline-block';
                    link.textContent = 'Process';
                    tdAction.appendChild(link);

                    row.append(tdDate, tdApplicant, tdType, tdDue, tdStatus, tdAction);
                    tbody.appendChild(row);
                });
            }
          }

          // Fetch Notifications
          const feed = document.getElementById('notifications-feed');
          if(feed) {
              const { data: notifs, error: nErr } = await supabase
                .from('notifications')
                .select('id, type, message, created_at, entity_id, entity_type')
                .eq('user_id', session.user.id)
                .eq('is_read', false)
                .order('created_at', { ascending: false })
                .limit(10);
                
              if (nErr) { 
                  feed.innerHTML = 'Error loading notifications.'; 
              }
              else if (!notifs || notifs.length === 0) { 
                  feed.innerHTML = '<span style="color:#94a3b8; font-size: 0.9rem;">No new notifications.</span>'; 
              } else {
                  feed.innerHTML = '';
                  notifs.forEach((n: any) => {
                      const d = document.createElement('div');
                      d.style = "padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 6px; font-size: 0.9rem; position: relative;";
                      
                      // Map the clickthrough route based on the entity type
                      let routeTarget = '#';
                      if(n.entity_type === 'submission' || n.entity_type === 'submission_file') {
                          routeTarget = `/staff/submissions/detail?id=${n.entity_id}`;
                      }

                      d.innerHTML = `
                        <div style="display: flex; justify-content: space-between; align-items:flex-start;">
                            <div>
                                <a href="${routeTarget}" style="text-decoration:none; color:inherit;" class="notif-link" data-id="${n.id}">
                                    <strong style="color:var(--color-sidebar); display:block; margin-bottom:4px;">${n.type.replace(/_/g, ' ').toUpperCase()}</strong>
                                    ${n.message}
                                </a>
                                <div style="margin-top: 6px;"><small style="color:#94a3b8;">${new Date(n.created_at).toLocaleDateString()}</small></div>
                            </div>
                            <button class="mark-read-btn" data-id="${n.id}" style="background:transparent; border:none; color:#cbd5e1; cursor:pointer;" title="Mark as read">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        </div>
                      `;
                      feed.appendChild(d);
                  });

                  // Bind mark-as-read buttons
                  document.querySelectorAll('.mark-read-btn').forEach(btn => {
                      btn.addEventListener('click', async (e) => {
                          const target = e.currentTarget as HTMLButtonElement;
                          const nId = target.dataset.id;
                          await supabase.from('notifications').update({ is_read: true, read_at: new Date().toISOString() }).eq('id', nId);
                          const container = target.closest('div')?.parentElement as HTMLElement | null;
                          if (container) container.style.opacity = '0.5';
                          target.remove();
                      });
                  });
                  
                  // Bind explicit clickthrough links to Auto-Mark as read
                  document.querySelectorAll('.notif-link').forEach(link => {
                      link.addEventListener('click', async (e) => {
                          const target = e.currentTarget as HTMLAnchorElement;
                          const nId = target.dataset.id;
                          await supabase.from('notifications').update({ is_read: true, read_at: new Date().toISOString() }).eq('id', nId);
                      });
                  });
              }
          }
      });
    </script>
</StaffPortalLayout>
