---
import StaffPortalLayout from '../../../layouts/StaffPortalLayout.astro';
---
<StaffPortalLayout title="New Submissions Queue">
    <div class="card">
        <h2>Intake Triage Queue</h2>
        <p style="color: #64748b; font-size: 0.9rem; margin-top: -0.5rem; margin-bottom: 1.5rem;">Recent submissions waiting for initial review or assignment.</p>
        
        <div class="table-responsive">
<table class="portal-table" id="new-submissions-table">
            <thead>
                <tr>
                    <th>Date Received</th>
                    <th>Applicant</th>
                    <th>Type</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="6">Loading triage queue...</td></tr>
            </tbody>
        </table>
</div>
    </div>

    <script>
        import { createClient } from '@supabase/supabase-js';
        if(!(window as any).supabase) { (window as any).supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL || "https://placeholder.supabase.co", import.meta.env.PUBLIC_SUPABASE_ANON_KEY || "public-anon-key"); } const supabase = (window as any).supabase;

        document.addEventListener('astro:page-load', async () => {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) { window.location.href = '/staff/login/'; return; }

            const tbody = document.querySelector('#new-submissions-table tbody');
            if(!tbody) return;

            // RLS filters automatically 
            const { data, error } = await supabase
                .from('submissions')
                .select('id, created_at, submitted_by_name, submitted_by_email, type, internal_priority, status')
                .eq('status', 'New')
                .order('created_at', { ascending: false });

            if (error) {
                tbody.innerHTML = `<tr><td colspan="6" style="color:red;">Error loading submissions: ${error.message}</td></tr>`;
                return;
            }

            if (!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding: 2rem; color: #94a3b8;">Queue empty. No new submissions pending triage.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            data.forEach((sub: any) => {
                const row = document.createElement('tr');
                const rDate = new Date(sub.created_at).toLocaleString();

                // Col: Date
                const tdDate = document.createElement('td');
                tdDate.textContent = rDate;

                // Col: Applicant — XSS-safe: use textContent, never innerHTML for user-submitted values
                const tdApplicant = document.createElement('td');
                const nameStrong = document.createElement('strong');
                nameStrong.textContent = sub.submitted_by_name;
                const emailSpan = document.createElement('span');
                emailSpan.style.color = '#64748b';
                emailSpan.style.fontSize = '0.85rem';
                emailSpan.textContent = sub.submitted_by_email;
                tdApplicant.appendChild(nameStrong);
                tdApplicant.appendChild(document.createElement('br'));
                tdApplicant.appendChild(emailSpan);

                // Col: Type (internal enum value — safe)
                const tdType = document.createElement('td');
                tdType.textContent = (sub.type || '').toUpperCase();

                // Col: Priority (internal enum value — safe)
                const tdPriority = document.createElement('td');
                tdPriority.textContent = sub.internal_priority || 'Normal';

                // Col: Status pill (internal enum value — safe)
                const tdStatus = document.createElement('td');
                const pill = document.createElement('span');
                pill.className = `status-pill status-${(sub.status || '').replace(/\s+/g, '')}`;
                pill.textContent = sub.status;
                tdStatus.appendChild(pill);

                // Col: Action link
                const tdAction = document.createElement('td');
                const link = document.createElement('a');
                link.href = `/staff/submissions/detail?id=${sub.id}`;
                link.className = 'btn-primary';
                link.style.textDecoration = 'none';
                link.style.display = 'inline-block';
                link.style.fontSize = '0.85rem';
                link.style.padding = '0.4rem 0.8rem';
                link.textContent = 'Review';
                tdAction.appendChild(link);

                row.append(tdDate, tdApplicant, tdType, tdPriority, tdStatus, tdAction);
                tbody.appendChild(row);
            });
        });
    </script>
</StaffPortalLayout>
