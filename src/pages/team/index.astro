---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Our Team">
  <div class="container" style="padding: var(--spacing-8) 0;">
    <header class="reveal-on-scroll" style="margin-bottom: var(--spacing-8); text-align:center; max-width: 800px; margin-inline: auto;">
      <h1 style="font-size: 3rem; color: var(--color-primary-blue); margin-bottom: var(--spacing-3);">Leadership & Clinicians</h1>
      <p style="font-size: 1.15rem; color: var(--color-text-muted); line-height: 1.6;">
        Our dedicated staff of administrators, certified rehabilitation counselors, and community mentors are here to lead by example, combining rigorous clinical expertise with profound empathy.
      </p>
    </header>

    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--spacing-6);">
      <!-- Executive Director -->
      <article class="card reveal-on-scroll stagger-1" style="text-align: center;">
        <div style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--color-bg-offset); border: 2px solid var(--color-border); margin: 0 auto var(--spacing-4);"></div>
        <h3 style="margin-bottom: var(--spacing-1); font-size: 1.4rem;">Dr. Sarah Jenkins</h3>
        <div style="color: var(--color-accent-gold); font-weight: 600; margin-bottom: var(--spacing-3); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Executive Director</div>
        <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6;">
          With over two decades of experience in community mental health architecture, Dr. Jenkins oversees the foundation's strategic direction and ensures all clinical operations adhere to the highest standard of empathetic care.
        </p>
      </article>

      <!-- Clinical Director -->
      <article class="card reveal-on-scroll stagger-2" style="text-align: center;">
        <div style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--color-bg-offset); border: 2px solid var(--color-border); margin: 0 auto var(--spacing-4);"></div>
        <h3 style="margin-bottom: var(--spacing-1); font-size: 1.4rem;">Marcus Thorne, LCSW-C</h3>
        <div style="color: var(--color-accent-gold); font-weight: 600; margin-bottom: var(--spacing-3); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Clinical Director</div>
        <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6;">
          Marcus spearheads our SUD and PRP programs. He specializes in trauma-informed care and cognitive behavioral therapies, empowering our clinical staff to deliver individualized recovery blueprints.
        </p>
      </article>

      <!-- Lead Case Manager -->
      <article class="card reveal-on-scroll stagger-3" style="text-align: center;">
        <div style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--color-bg-offset); border: 2px solid var(--color-border); margin: 0 auto var(--spacing-4);"></div>
        <h3 style="margin-bottom: var(--spacing-1); font-size: 1.4rem;">Elena Rodriguez</h3>
        <div style="color: var(--color-accent-gold); font-weight: 600; margin-bottom: var(--spacing-3); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Lead Care Coordinator</div>
        <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6;">
          Elena is the vital bridge between our clients and external community resources. She expertly manages complex intake pipelines, ensuring every individual receives a seamless, warm hand-off into our programs.
        </p>
      </article>
    </div>
  </div>
</Layout>
