---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero" style="position: relative; overflow: hidden; min-height: 85vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);">
    
    <!-- Sophisticated CSS Gradient Mesh (Slow rotation) -->
    <div class="hero-mesh" aria-hidden="true"></div>

    <div class="container" style="position: relative; z-index: 10; width: 100%; text-align: center; padding-top: var(--spacing-8);">
      <div class="reveal-on-scroll" style="display: inline-block; margin-bottom: var(--spacing-4);">
        <span style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 40px; padding: 0.5rem 1.5rem; font-size: 0.85rem; font-weight: 600; color: #FFFFFF; letter-spacing: 0.05em; text-transform: uppercase;">Elevating Lives in Baltimore</span>
      </div>
      
      <h1 class="reveal-on-scroll stagger-1" style="color: #FFFFFF; font-size: clamp(3.5rem, 8vw, 5.5rem); letter-spacing: -0.03em; line-height: 1.05; max-width: 1000px; margin-inline: auto; font-weight: 700;">
        Clinical Mastery.<br />
        <span style="color: var(--color-accent-gold-muted);">Unwavering</span> Compassion.
      </h1>
      
      <p class="reveal-on-scroll stagger-2" style="font-size: 1.25rem; line-height: 1.6; color: #CBD5E1; max-width: 700px; margin: 0 auto var(--spacing-8);">
        The WEL Foundation is Baltimore’s premier behavioral health institution. We fuse elite clinical precision with absolute empathy to architect profound, lasting recovery for every individual.
      </p>
      
      <div class="reveal-on-scroll stagger-3 hero-ctas" style="display: inline-flex; flex-wrap: wrap; gap: var(--spacing-3); padding: var(--spacing-2); border-radius: 50px; justify-content: center;">
        <a href="/intake/start/" class="btn" style="min-width: 160px; background-color: var(--color-accent-gold-muted); color: white;">Start Intake</a>
        <a href="/programs/" class="btn btn-secondary cta-link" style="min-width: 160px; border: 1px solid var(--color-accent-gold-muted); color: var(--color-accent-gold-muted); background: transparent;">
          View Programs 
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section aria-label="Key Metrics" style="padding: var(--spacing-6) 0; background-color: var(--color-bg-surface); border-top: var(--border-delicate); border-bottom: var(--border-delicate);">
    <div class="container flex" style="justify-content: space-evenly; flex-wrap: wrap; gap: var(--spacing-5); text-align: center;">
      <div class="reveal-on-scroll">
        <div style="font-size: 2rem; font-weight: 600; font-family: var(--font-family-heading); color: var(--color-primary-navy);">Maryland</div>
        <div style="color: var(--color-text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">State Certified</div>
      </div>
      <div class="reveal-on-scroll stagger-1">
        <div style="font-size: 2rem; font-weight: 600; font-family: var(--font-family-heading); color: var(--color-primary-navy);">Medicaid</div>
        <div style="color: var(--color-text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Accepted Partner</div>
      </div>
      <div class="reveal-on-scroll stagger-2">
        <div style="font-size: 2rem; font-weight: 600; font-family: var(--font-family-heading); color: var(--color-primary-navy);">15+</div>
        <div style="color: var(--color-text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Expert Clinicians</div>
      </div>
      <div class="reveal-on-scroll stagger-3">
        <div style="font-size: 2rem; font-weight: 600; font-family: var(--font-family-heading); color: var(--color-primary-navy);">98%</div>
        <div style="color: var(--color-text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Completion Rate</div>
      </div>
    </div>
  </section>

  <!-- Premium Programs Overview -->
  <section class="programs-overview" style="padding: var(--spacing-12) 0; background-color: var(--color-bg-base);">
    <div class="container">
      <div class="reveal-on-scroll" style="max-width: 650px; margin-bottom: var(--spacing-8);">
        <h2 style="font-size: 2.5rem; letter-spacing: -0.02em;">Surgical Precision. Holistic Healing.</h2>
        <p style="font-size: 1.15rem; color: var(--color-text-secondary);">Discover elite behavioral health programs meticulously engineered to sever dependencies, rebuild confidence, and empower communities.</p>
      </div>
      
      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-5);">
        <!-- SUD Program -->
        <article class="card reveal-on-scroll stagger-1" style="display: flex; flex-direction: column;">
          <div style="margin-bottom: var(--spacing-4); padding: 12px; background-color: var(--color-bg-base); display: inline-flex; border-radius: var(--radius-sm); border: var(--border-delicate);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-navy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
          </div>
          <h3 style="font-size: 1.4rem; margin-bottom: var(--spacing-2);">Substance Use Disorder</h3>
          <p style="color: var(--color-text-secondary); line-height: 1.6; margin-bottom: var(--spacing-6); flex-grow: 1;">Break the cycle of chemical reliance with high-impact, transformative outpatient therapy driven by proven cognitive retraining protocols.</p>
          <a href="/programs/sud/" class="cta-link">
            Explore SUD
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </article>

        <!-- PRP Program -->
        <article class="card reveal-on-scroll stagger-2" style="display: flex; flex-direction: column;">
          <div style="margin-bottom: var(--spacing-4); padding: 12px; background-color: var(--color-bg-base); display: inline-flex; border-radius: var(--radius-sm); border: var(--border-delicate);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-navy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3 style="font-size: 1.4rem; margin-bottom: var(--spacing-2);">Psychiatric Rehabilitation</h3>
          <p style="color: var(--color-text-secondary); line-height: 1.6; margin-bottom: var(--spacing-6); flex-grow: 1;">Master life-skills and re-integrate seamlessly. We supply the invincible operational framework to fortify your clinical breakthroughs.</p>
          <a href="/programs/prp/" class="cta-link">
            Explore PRP
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </article>

        <!-- DUI Program -->
        <article class="card reveal-on-scroll stagger-3" style="display: flex; flex-direction: column;">
          <div style="margin-bottom: var(--spacing-4); padding: 12px; background-color: var(--color-bg-base); display: inline-flex; border-radius: var(--radius-sm); border: var(--border-delicate);">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-navy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 style="font-size: 1.4rem; margin-bottom: var(--spacing-2);">DUI / DWI Mitigation</h3>
          <p style="color: var(--color-text-secondary); line-height: 1.6; margin-bottom: var(--spacing-6); flex-grow: 1;">State-certified MVA mitigation curricula engineered for rapid compliance, deep education, and fundamental behavioral corrections.</p>
          <a href="/programs/dui-dwi/" class="cta-link">
            View Classes
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- Editorial "Why WEL" Split Layout -->
  <section class="why-wel" style="padding: var(--spacing-12) 0; background-color: var(--color-bg-surface); border-top: var(--border-delicate);">
    <div class="container">
      <div class="split-grid">
        <!-- Sticky Left Column -->
        <div class="sticky-column">
          <div class="reveal-on-scroll">
            <div style="width: 40px; height: 3px; background-color: var(--color-accent-gold-muted); margin-bottom: var(--spacing-4);"></div>
            <h2 style="font-size: 3rem; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: var(--spacing-4);">
              Beyond Treatment. We Architect Transformation.
            </h2>
            <img src="/images/clinical_therapy.png" alt="Clinical Therapy" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--radius-lg); margin-bottom: var(--spacing-4); box-shadow: var(--shadow-premium-soft);" />
            <p style="font-size: 1.15rem; color: var(--color-text-secondary); line-height: 1.6;">
              Healing is not a passive journey. It demands an incredibly powerful alliance of clinical frameworks, cultural fluency, and absolute respect for the individual.
            </p>
          </div>
        </div>
        
        <!-- Scrolling Right Column -->
        <div class="scrolling-pillars flex-col" style="gap: var(--spacing-8);">
          <div class="reveal-on-scroll">
            <h3 style="font-size: 1.5rem; color: var(--color-primary-navy); margin-bottom: var(--spacing-2);">01 / Radical Dignity</h3>
            <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.05rem;">We permanently strip away the sterile institutional chill. Every client receives absolute dignity, zero judgment, and unwavering support regardless of their complex histories.</p>
          </div>
          
          <div class="reveal-on-scroll">
            <h3 style="font-size: 1.5rem; color: var(--color-primary-navy); margin-bottom: var(--spacing-2);">02 / Cultural Mastery</h3>
            <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.05rem;">Healing in Baltimore demands an understanding of its unique environments. Our clinicians are embedded directly in the community, crafting nuanced, ultra-relevant recovery protocols.</p>
          </div>
          
          <div class="reveal-on-scroll">
            <h3 style="font-size: 1.5rem; color: var(--color-primary-navy); margin-bottom: var(--spacing-2);">03 / Actionable Architecture</h3>
            <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.05rem;">Therapy provides the crucial blueprint, but we lay the actual mortar. From immediate job readiness interventions to housing navigation, our results are aggressively tangible.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intake vs Referral Gateway -->
  <section class="gateway" style="padding: var(--spacing-12) 0; background-color: var(--color-bg-base); position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(13, 27, 42, 0.03) 0%, transparent 100%); pointer-events: none;"></div>
    <div class="container" style="position: relative; z-index: 5;">
      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--spacing-6);">
        
        <!-- Client Gateway -->
        <article class="card reveal-on-scroll" style="background: var(--color-surface-glass); backdrop-filter: saturate(180%) blur(20px); border: var(--border-gold-subtle);">
          <h3 style="font-size: 1.6rem; color: var(--color-primary-navy); margin-bottom: var(--spacing-2);">Begin Your Transformation</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-5);">Engage with our confidential digital intake system. An elite coordinator will immediately assess eligibility and fast-track your clinical evaluation.</p>
          <a href="/intake/start/" class="btn" style="width: 100%;">Start Secure Intake</a>
        </article>

        <!-- Provider Gateway -->
        <article class="card reveal-on-scroll stagger-1" style="border: var(--border-delicate);">
          <h3 style="font-size: 1.6rem; color: var(--color-primary-navy); margin-bottom: var(--spacing-2);">Provider Dispatch</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-5);">Hospitals, private practices, and case managers can securely inject HIPAA-compliant client referrals straight into our evaluation queue.</p>
          <a href="/referral/start/" class="btn btn-secondary" style="width: 100%;">Access Provider Gateway</a>
        </article>

      </div>
    </div>
  </section>

  <!-- Contact/Location Confidence Block -->
  <section class="location-block" style="padding: var(--spacing-8) 0; background-color: var(--color-bg-surface); border-top: var(--border-delicate);">
    <div class="container">
       <div class="card reveal-on-scroll" style="display: flex; flex-wrap: wrap; gap: var(--spacing-6); padding: var(--spacing-8); align-items: center; border: none; box-shadow: none; background-color: var(--color-bg-base);">
          <div style="flex: 1; min-width: 300px;">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background-color: var(--color-bg-surface); border: var(--border-delicate); margin-bottom: var(--spacing-4);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-navy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <h2 style="font-size: 2rem; margin-bottom: var(--spacing-2);">Anchored in Baltimore.</h2>
            <p style="font-size: 1.1rem; color: var(--color-text-secondary); margin-bottom: var(--spacing-5);">Operating from the very heart of Maryland, relentlessly serving our community.</p>
            
            <address style="font-style: normal; color: var(--color-primary-navy); font-size: 1.05rem; line-height: 1.6;">
              <strong>The WEL Foundation HQ</strong><br />
              5858 Belair Rd<br />
              Baltimore, MD 21206<br />
              <div style="margin-top: var(--spacing-3);">
                <a href="tel:443-826-2770" style="font-weight: 500; font-size: 1.2rem; border-bottom: 2px solid var(--color-accent-gold-muted); padding-bottom: 2px;">443-826-2770</a>
              </div>
            </address>
          </div>
          <!-- Clean Placeholder for Maps/Imagery -->
          <div class="reveal-on-scroll" style="flex: 1; min-width: 300px;">
             <img src="/images/baltimore.png" alt="Baltimore Medical Architecture" style="width: 100%; height: auto; border-radius: var(--radius-lg); box-shadow: var(--shadow-premium-hover);" />
          </div> <!-- In production, replace with elegant static map or facility photo -->
       </div>
    </div>
  </section>

  <!-- Interactive Styles for this page -->
  <style>
    /* Premium Slow Radial Gradient Animation */
    .hero-mesh {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      pointer-events: none;
      z-index: 0;
      /* Soft Apple-like glass glows */
      background: 
        radial-gradient(circle at 50% 50%, rgba(13, 27, 42, 0.03) 0%, transparent 40%), 
        radial-gradient(circle at 60% 40%, rgba(217, 119, 6, 0.04) 0%, transparent 50%),
        radial-gradient(circle at 40% 60%, rgba(13, 27, 42, 0.02) 0%, transparent 60%);
      animation: rotateMesh 45s linear infinite;
    }

    @keyframes rotateMesh {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Sticky Editorial Grid Split */
    .split-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--spacing-8);
    }
    
    @media (min-width: 900px) {
      .split-grid {
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-10);
      }
      .sticky-column {
        position: sticky;
        top: 15vh;
        height: fit-content;
      }
    }

    /* Mobile: stack hero CTAs and reduce hero padding */
    @media (max-width: 600px) {
      .hero-ctas {
        flex-direction: column;
        align-items: stretch;
        width: 100%;
        max-width: 320px;
        padding: 0;
      }

      .hero-ctas .btn,
      .hero-ctas .btn-secondary {
        width: 100%;
        min-width: unset;
        justify-content: center;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-mesh { animation: none !important; }
    }
  </style>

</Layout>
