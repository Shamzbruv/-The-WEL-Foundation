    border-color: #bfdbfe !important;
    border-radius: 6px;
    border-width: 1.5px;
    border-style: solid;
  }

  .consent-body {
    font-size: 0.86rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .consent-body p { margin-bottom: 8px; }
  .consent-body ul { padding-left: 18px; margin-bottom: 8px; }
  .consent-body li { margin-bottom: 4px; }

  .crisis-box {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 0.84rem;
