<style>
  /* ===== RESET & BASE ===== */
  :root {
    --prp-accent: #1B4F72;
    --prp-accent-light: rgba(27,79,114,0.1);
    --gold: #b45309;
    --success: #16a34a;
    --danger: #dc2626;
    --border: #e2e8f0;
    --bg: #f8fafc;
    --card-bg: #ffffff;
    --text: #0f172a;
    --muted: #64748b;
    --radius: 14px;
    --radius-sm: 8px;
    --shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
    --shadow-lg: 0 4px 24px rgba(0,0,0,0.1), 0 1px 4px rgba(0,0,0,0.06);
  }

  .intake-shell {
    min-height: 100vh;
    background: var(--bg);
    padding-bottom: 100px;
  }

  /* ===== TOPBAR ===== */
  .intake-topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: white;
    border-bottom: 1px solid var(--border);
    box-shadow: 0 1px 8px rgba(0,0,0,0.04);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--prp-accent); }

  .topbar-badge {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--prp-accent);
    background: var(--prp-accent-light);
    padding: 4px 12px;
    border-radius: 40px;
  }

  .topbar-pct {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--prp-accent);
    min-width: 40px;
    text-align: right;
  }

  /* ===== PROGRESS ===== */
  .progress-rail {
    height: 4px;
    background: var(--border);
    position: sticky;
    top: 53px;
    z-index: 99;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--prp-accent), #2980b9);
    border-radius: 0 2px 2px 0;
    transition: width 0.5s cubic-bezier(0.65, 0, 0.35, 1);
  }

  /* ===== SECTION META ===== */
  .section-meta {
    text-align: center;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    padding: 10px 20px 0;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* ===== FORM SECTIONS ===== */
  .form-section {
    display: none;
    max-width: 680px;
    margin: 0 auto;
    padding: 24px 20px 0;
    animation: sectionIn 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .form-section.active { display: block; }

  @keyframes sectionIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== SECTION HEADER ===== */
  .section-header { text-align: center; margin-bottom: 24px; }

  .section-icon {
    font-size: 2.4rem;
    margin-bottom: 10px;
    display: block;
  }

  .section-header h2 {
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .section-header p {
    font-size: 0.93rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 480px;
    margin-inline: auto;
  }

  .consent-subtitle {
    background: rgba(27,79,114,0.07);
    border: 1px solid rgba(27,79,114,0.15);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.88rem !important;
    color: var(--prp-accent) !important;
  }

  /* ===== CARDS ===== */
  .form-card, .consent-card, .signature-card, .review-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
  }

  .signature-card { border-top: 3px solid var(--prp-accent); }

  /* ===== FIELDS ===== */
  .field-group { margin-bottom: 16px; }

  .field-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }

  .field-input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    color: var(--text);
    background: #fff;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .field-input:focus {
    outline: none;
    border-color: var(--prp-accent);
    box-shadow: 0 0 0 3px rgba(27,79,114,0.1);
  }

  .field-input[aria-invalid="true"],
  .field-input.has-error {
    border-color: var(--danger);
    box-shadow: 0 0 0 3px rgba(220,38,38,0.1);
  }

  select.field-input { cursor: pointer; }
  textarea.field-input { resize: vertical; min-height: 80px; }

  .field-error {
    display: none;
    font-size: 0.78rem;
    color: var(--danger);
    margin-top: 4px;
    font-weight: 600;
  }

  .field-hint { font-size: 0.78rem; color: var(--muted); margin-top: 4px; display: block; }
  .field-opt { font-size: 0.78rem; font-weight: 400; color: var(--muted); }
  .req { color: var(--danger); }

  /* Auto-fill */
  .autofill-input {
    background: #eff6ff !important;
    border-color: #bfdbfe !important;
    cursor: default;
  }

  .autofill-label { color: var(--prp-accent) !important; }

  .autofill-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--prp-accent);
    background: var(--prp-accent-light);
    padding: 2px 7px;
    border-radius: 20px;
    margin-left: 5px;
  }

  .autofill-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: 9px 14px;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .signature-style {
    font-family: 'Georgia', 'Times New Roman', serif !important;
    font-style: italic;
    font-size: 1.05rem !important;
    letter-spacing: 0.01em;
  }

  /* ===== GRIDS ===== */
  .field-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
  @media (max-width: 560px) {
    .field-row-2, .field-row-3 { grid-template-columns: 1fr; }
  }

  /* ===== RADIO & CHECKBOX ===== */
  .radio-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .radio-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px;
    border: 1.5px solid var(--border);
    border-radius: 40px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    color: var(--text);
    background: white;
  }

  .radio-pill:has(input:checked) {
    border-color: var(--prp-accent);
    background: var(--prp-accent-light);
    color: var(--prp-accent);
    font-weight: 700;
  }

  .radio-pill input { width: 14px; height: 14px; accent-color: var(--prp-accent); flex-shrink: 0; }

  .checkbox-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: var(--text);
    cursor: pointer;
    padding: 4px 0;
  }

  .checkbox-pill input { width: 16px; height: 16px; accent-color: var(--prp-accent); flex-shrink: 0; }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 8px;
    margin-top: 8px;
  }

  .radio-stack { display: flex; flex-direction: column; gap: 8px; margin-top: 8px; }

  .radio-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    cursor: pointer;
    transition: all 0.15s;
    background: white;
  }

  .radio-card:has(input:checked) {
    border-color: var(--prp-accent);
    background: var(--prp-accent-light);
    color: var(--prp-accent);
    font-weight: 600;
  }

  .radio-card input { width: 16px; height: 16px; accent-color: var(--prp-accent); flex-shrink: 0; margin-top: 2px; }

  /* ===== CONSENT CARDS ===== */
  .consent-card {
    padding: 18px;
    border-left: 3px solid var(--prp-accent);
  }

  .consent-card-header {
    display: flex;
