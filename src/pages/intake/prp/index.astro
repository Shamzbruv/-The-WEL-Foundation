---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="PRP Intake Form — The WEL Foundation">

<div class="intake-shell">

  <!-- Sticky Top Bar -->
  <div class="intake-topbar">
    <a href="/intake/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back
    </a>
    <div class="topbar-badge">PRP — Psychiatric Rehabilitation</div>
    <div class="topbar-pct" id="pct-display">0%</div>
  </div>

  <!-- Progress Bar -->
  <div class="progress-rail">
    <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
  </div>

  <!-- Section Counter -->
  <div class="section-meta" id="section-meta">Section 1 of 17 &mdash; <span id="section-label-text">Your Name</span></div>

  <!-- Form -->
  <form id="prp-form" novalidate>

    <!-- =================== SECTION 1: NAME =================== -->
    <div class="form-section active" id="s1" data-label="Your Name">
      <div class="section-header">
        <div class="section-icon">👤</div>
        <h2>What's your name?</h2>
        <p>This will be used to automatically fill in your name and initials throughout the form — you won't have to type it again.</p>
      </div>
      <div class="field-group">
        <label class="field-label" for="fullname">Full Legal Name <span class="req">*</span></label>
        <input class="field-input" type="text" id="fullname" name="fullName" placeholder="e.g. Jane Marie Smith" required autocomplete="name" />
        <div class="field-error" id="err-fullname">Please enter your full name.</div>
      </div>
      <div class="field-group">
        <label class="field-label" for="dob">Date of Birth <span class="req">*</span></label>
        <input class="field-input" type="date" id="dob" name="dateOfBirth" required />
        <div class="field-error" id="err-dob">Please enter your date of birth.</div>
      </div>
      <div class="field-group">
        <label class="field-label" for="ssn">Social Security # <span class="field-opt">(optional)</span></label>
        <input class="field-input" type="text" id="ssn" name="ssn" placeholder="XXX-XX-XXXX" autocomplete="off" />
      </div>
    </div>

    <!-- =================== SECTION 2: GOV ID =================== -->
    <div class="form-section" id="s2" data-label="Government ID">
      <div class="section-header">
        <div class="section-icon">🪪</div>
        <h2>Upload your Government ID</h2>
        <p>We need a copy of your driver's license, state ID, or passport to open your file. You can take a photo on your phone.</p>
      </div>
      <div class="upload-zone" id="govid-zone">
        <input type="file" id="gov-id" name="govId" accept="image/jpeg,image/png,application/pdf" required aria-required="true" class="upload-input" />
        <div class="upload-zone-inner" id="govid-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <p class="upload-title">Tap to upload your ID</p>
          <p class="upload-hint">JPG, PNG, or PDF · Max 10MB</p>
        </div>
      </div>
      <div class="field-error" id="err-gov-id">Please upload your government ID.</div>
      <div class="upload-success" id="govid-success" style="display:none;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="govid-filename">ID uploaded</span>
      </div>
    </div>

    <!-- =================== SECTION 3: INSURANCE =================== -->
    <div class="form-section" id="s3" data-label="Insurance Card">
      <div class="section-header">
        <div class="section-icon">🛡️</div>
        <h2>Upload your Insurance Card</h2>
        <p>Please upload the front of your Medicaid, Medicare, or private insurance card.</p>
      </div>
      <div class="upload-zone" id="insurance-zone">
        <input type="file" id="insurance-card" name="insuranceCard" accept="image/jpeg,image/png,application/pdf" required aria-required="true" class="upload-input" />
        <div class="upload-zone-inner" id="insurance-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p class="upload-title">Tap to upload your insurance card</p>
          <p class="upload-hint">JPG, PNG, or PDF · Max 10MB</p>
        </div>
      </div>
      <div class="field-error" id="err-insurance-card">Please upload your insurance card.</div>
      <div class="upload-success" id="insurance-success" style="display:none;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="insurance-filename">Card uploaded</span>
      </div>
    </div>

    <!-- =================== SECTION 4: CONTACT INFO =================== -->
    <div class="form-section" id="s4" data-label="Contact Information">
      <div class="section-header">
        <div class="section-icon">📋</div>
        <h2>Contact Information</h2>
        <p>Tell us how to reach you and where you live.</p>
      </div>
      <div class="autofill-pill">✓ Your name has been filled in automatically</div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label">Referral Source</label>
          <input class="field-input" type="text" name="referralSource" placeholder="Who referred you?" />
        </div>
        <div class="field-group">
          <label class="field-label">Date of Admission</label>
          <input class="field-input" type="date" name="dateOfAdmission" />
        </div>
      </div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label autofill-label">Client Name <span class="autofill-tag">Auto</span></label>
          <input class="field-input autofill-input" type="text" name="fs_name" readonly />
        </div>
        <div class="field-group">
          <label class="field-label autofill-label">Date of Intake <span class="autofill-tag">Auto</span></label>
          <input class="field-input autofill-input" type="date" name="fs_dateOfIntake" readonly class="today-field" />
        </div>
      </div>
      <div class="field-group">
        <label class="field-label" for="address">Home Address <span class="req">*</span></label>
        <input class="field-input" type="text" id="address" name="address" placeholder="Street address" required />
        <div class="field-error" id="err-address">Please enter your address.</div>
      </div>
      <div class="field-group">
        <label class="field-label">Are you currently homeless?</label>
        <div class="radio-row">
          <label class="radio-pill"><input type="radio" name="isHomeless" value="no" checked /> No</label>
          <label class="radio-pill"><input type="radio" name="isHomeless" value="yes" /> Yes</label>
        </div>
      </div>
      <div class="field-row-3">
        <div class="field-group"><label class="field-label">Cell Phone</label><input class="field-input" type="tel" name="cellPhone" placeholder="(   )   -    " /></div>
        <div class="field-group"><label class="field-label">Home Phone</label><input class="field-input" type="tel" name="homePhone" placeholder="(   )   -    " /></div>
        <div class="field-group"><label class="field-label">Other Phone</label><input class="field-input" type="tel" name="otherPhone" placeholder="(   )   -    " /></div>
      </div>
    </div>

    <!-- =================== SECTION 5: PERSONAL INFO =================== -->
    <div class="form-section" id="s5" data-label="Personal Details">
      <div class="section-header">
        <div class="section-icon">🏷️</div>
        <h2>Personal Details</h2>
        <p>These help us understand your background and provide culturally appropriate care.</p>
      </div>
      <div class="field-row-3">
        <div class="field-group"><label class="field-label">Age</label><input class="field-input" type="number" name="age" min="1" max="120" /></div>
        <div class="field-group"><label class="field-label">Race</label><input class="field-input" type="text" name="race" /></div>
        <div class="field-group"><label class="field-label">Gender Identity</label><input class="field-input" type="text" name="genderIdentity" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Sexual Orientation <span class="field-opt">(optional)</span></label><input class="field-input" type="text" name="sexualOrientation" /></div>
        <div class="field-group"><label class="field-label">Preferred Pronouns <span class="field-opt">(optional)</span></label><input class="field-input" type="text" name="pronouns" placeholder="e.g. She/Her, He/Him" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label">Religious Affiliation <span class="field-opt">(optional)</span></label>
          <input class="field-input" type="text" name="religiousAffiliation" />
          <label class="checkbox-pill" style="margin-top:6px;"><input type="checkbox" name="religionNA" /> N/A</label>
        </div>
        <div class="field-group">
          <label class="field-label">Cultural Identity</label>
          <input class="field-input" type="text" name="culturalIdentity" />
        </div>
      </div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label">Highest Grade Completed</label>
          <input class="field-input" type="text" name="educationLevel" placeholder="e.g. 12th grade, GED, College" />
        </div>
        <div class="field-group">
          <label class="field-label">Current Employment Status</label>
          <select class="field-input" name="employmentStatus">
            <option value="">Select one...</option>
            <option>Employed full-time</option>
            <option>Employed part-time</option>
            <option>Unemployed / Seeking</option>
            <option>Receiving Public Assistance</option>
            <option>Not applicable</option>
          </select>
        </div>
      </div>
      <div class="field-group" id="employer-section">
        <label class="field-label">Current Employer (if employed)</label>
        <input class="field-input" type="text" name="employer" placeholder="Employer name" />
        <input class="field-input" type="text" name="employerAddress" placeholder="Employer address" style="margin-top:8px;" />
        <input class="field-input" type="tel" name="employerPhone" placeholder="Employer phone" style="margin-top:8px;" />
      </div>
      <div class="field-group">
        <label class="field-label">Current Relationship / Marital Status</label>
        <div class="radio-row flex-wrap">
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="single" /> Single</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="married" /> Married</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="separated" /> Separated</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="divorced" /> Divorced</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="widowed" /> Widowed</label>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Preferred Language</label>
        <div class="radio-row flex-wrap">
          <label class="radio-pill"><input type="radio" name="language" value="english" /> English</label>
          <label class="radio-pill"><input type="radio" name="language" value="spanish" /> Spanish</label>
          <label class="radio-pill"><input type="radio" name="language" value="asl" /> ASL</label>
          <label class="radio-pill"><input type="radio" name="language" value="other" /> Other: <input type="text" name="languageOther" style="width:120px; margin-left:6px; border:none; border-bottom:1px solid #cbd5e1; background:transparent; font-size:0.9rem;" /></label>
        </div>
      </div>
    </div>

    <!-- =================== SECTION 6: EMERGENCY CONTACT =================== -->
    <div class="form-section" id="s6" data-label="Emergency Contact">
      <div class="section-header">
        <div class="section-icon">🚨</div>
        <h2>Emergency Contact</h2>
        <p>Who should we call if we can't reach you?</p>
      </div>
      <div class="field-group">
        <label class="field-label" for="emg-name">Full Name <span class="req">*</span></label>
        <input class="field-input" type="text" id="emg-name" name="emergencyContactName" required />
        <div class="field-error" id="err-emg-name">Please enter an emergency contact name.</div>
      </div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label" for="emg-relationship">Relationship to You <span class="req">*</span></label>
          <input class="field-input" type="text" id="emg-relationship" name="emergencyContactRelationship" placeholder="e.g. Mother, Spouse" required />
          <div class="field-error" id="err-emg-relationship">Please enter their relationship.</div>
        </div>
        <div class="field-group">
          <label class="field-label" for="emg-phone">Phone Number <span class="req">*</span></label>
          <input class="field-input" type="tel" id="emg-phone" name="emergencyContactPhone" required />
          <div class="field-error" id="err-emg-phone">Please enter their phone number.</div>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Emergency Contact Address</label>
        <input class="field-input" type="text" name="emergencyContactAddress" placeholder="Street address" />
        <label class="checkbox-pill" style="margin-top:6px;"><input type="checkbox" name="emgAddressUnknown" /> Address is unknown</label>
      </div>
    </div>

    <!-- =================== SECTION 7: MEDICAL INFO =================== -->
    <div class="form-section" id="s7" data-label="Medical & Insurance">
      <div class="section-header">
        <div class="section-icon">🏥</div>
        <h2>Medical &amp; Insurance Information</h2>
        <p>Your medical history and insurance details.</p>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Medicaid / MA#</label><input class="field-input" type="text" name="maNumber" placeholder="MA#" /></div>
        <div class="field-group"><label class="field-label">MCO Name</label><input class="field-input" type="text" name="mcoName" placeholder="e.g. Careleon, Optum" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Other Primary Insurance #</label><input class="field-input" type="text" name="otherInsuranceNumber" /></div>
        <div class="field-group"><label class="field-label">Group #</label><input class="field-input" type="text" name="groupNumber" /></div>
      </div>
      <div class="field-group"><label class="field-label">Current Medical Issues / Diagnoses</label><textarea class="field-input" name="medicalIssues" rows="2" placeholder="List any medical conditions or diagnoses"></textarea></div>
      <div class="field-group"><label class="field-label">Current Mental Health Diagnosis</label><textarea class="field-input" name="mentalHealthDiagnosis" rows="2" placeholder="List any mental health diagnoses"></textarea></div>
      <div class="field-group"><label class="field-label">Allergies</label><input class="field-input" type="text" name="allergies" placeholder="List allergies, or type 'None'" /></div>
      <div class="field-group">
        <label class="field-label">Do you currently receive any benefits or entitlements?</label>
        <div class="radio-row">
          <label class="radio-pill"><input type="radio" name="hasBenefits" value="no" checked /> No</label>
          <label class="radio-pill"><input type="radio" name="hasBenefits" value="yes" /> Yes</label>
        </div>
        <input class="field-input" type="text" id="benefits-detail" name="benefitsDetail" placeholder="e.g. SSI, Medicaid, SNAP" style="display:none; margin-top:8px;" />
      </div>
    </div>

    <!-- =================== SECTION 8: PCP =================== -->
    <div class="form-section" id="s8" data-label="Primary Care Physician">
      <div class="section-header">
        <div class="section-icon">👨‍⚕️</div>
        <h2>Primary Care Physician</h2>
        <p>Tell us about your regular doctor. If you don't have one, that's okay.</p>
      </div>
      <div class="field-group">
        <label class="field-label">Do you have a Primary Care Doctor?</label>
        <div class="radio-row">
          <label class="radio-pill"><input type="radio" name="hasPCP" value="no" checked /> No</label>
          <label class="radio-pill"><input type="radio" name="hasPCP" value="yes" /> Yes</label>
        </div>
      </div>
      <div id="pcp-fields" style="display:none;">
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">Doctor's Name</label><input class="field-input" type="text" name="pcpName" /></div>
          <div class="field-group"><label class="field-label">Doctor's Phone</label><input class="field-input" type="tel" name="pcpPhone" /></div>
        </div>
        <div class="field-group"><label class="field-label">Doctor's Street Address</label><input class="field-input" type="text" name="pcpStreet" /></div>
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">City</label><input class="field-input" type="text" name="pcpCity" /></div>
          <div class="field-group"><label class="field-label">Date of Last Exam</label><input class="field-input" type="date" name="pcpLastExam" /></div>
        </div>
      </div>
      <div class="field-group" style="margin-top: var(--spacing-4);">
        <label class="field-label">Please check if you do NOT currently have a PCP and will inform WEL when one is located:</label>
        <label class="checkbox-pill"><input type="checkbox" name="noPCPAcknowledge" /> I don't have a PCP and will notify WEL when I find one</label>
      </div>
    </div>

    <!-- =================== SECTION 9: MEDICATIONS =================== -->
    <div class="form-section" id="s9" data-label="Medications">
      <div class="section-header">
        <div class="section-icon">💊</div>
        <h2>Current Medications</h2>
        <p>List everything you're currently taking — prescription and over-the-counter. Add rows as needed.</p>
      </div>
      <div class="med-table-wrap">
        <table class="med-table">
          <thead><tr><th>Medication Name</th><th>Dose / How Often</th><th>Prescribing Doctor</th><th>Start Date</th><th></th></tr></thead>
          <tbody id="med-body">
            <tr><td><input type="text" name="meds[0][name]" placeholder="Medication" /></td><td><input type="text" name="meds[0][dose]" placeholder="e.g. 10mg daily" /></td><td><input type="text" name="meds[0][prescriber]" placeholder="Doctor name" /></td><td><input type="date" name="meds[0][startDate]" /></td><td></td></tr>
          </tbody>
        </table>
      </div>
      <button type="button" class="btn-add-row" id="add-med">+ Add another medication</button>
      <label class="checkbox-pill" style="margin-top: var(--spacing-3);"><input type="checkbox" name="noMeds" id="no-meds" /> I am not currently taking any medications</label>
    </div>

    <!-- =================== SECTION 10: CHILD/TEEN =================== -->
    <div class="form-section" id="s10" data-label="For Minors (if applicable)">
      <div class="section-header">
        <div class="section-icon">👨‍👩‍👧</div>
        <h2>For Children &amp; Teens Under 18</h2>
        <p>Skip this section if you are 18 or older.</p>
      </div>
      <div class="field-group">
        <label class="checkbox-pill"><input type="checkbox" name="isAdult" id="is-adult" checked /> I am 18 or older — skip this section</label>
      </div>
      <div id="guardian-fields">
        <div class="field-group"><label class="field-label">Parent / Guardian Name</label><input class="field-input" type="text" name="guardianName" /></div>
        <div class="field-group"><label class="field-label">Guardian Address (if different from child)</label><input class="field-input" type="text" name="guardianAddress" /></div>
        <div class="field-row-3">
          <div class="field-group"><label class="field-label">Guardian Cell</label><input class="field-input" type="tel" name="guardianCell" /></div>
          <div class="field-group"><label class="field-label">Guardian Home</label><input class="field-input" type="tel" name="guardianHome" /></div>
          <div class="field-group"><label class="field-label">Guardian Work</label><input class="field-input" type="tel" name="guardianWork" /></div>
        </div>
        <div class="field-group"><label class="field-label">Guardian Email</label><input class="field-input" type="email" name="guardianEmail" /></div>
        <div class="field-group">
          <label class="field-label">Guardian Preferred Communication</label>
          <div class="radio-row">
            <label class="radio-pill"><input type="checkbox" name="guardianCommEmail" /> Email</label>
            <label class="radio-pill"><input type="checkbox" name="guardianCommPhone" /> Phone</label>
            <label class="radio-pill"><input type="checkbox" name="guardianCommText" /> Text</label>
          </div>
        </div>
      </div>
    </div>

    <!-- =================== SECTION 11: CONSENT — SERVICES =================== -->
    <div class="form-section" id="s11" data-label="Consent — Services">
      <div class="section-header">
        <div class="section-icon">📄</div>
        <h2>Consent for Treatment</h2>
        <p class="consent-subtitle">Please read each section and check the box to confirm. Your initials are already filled in.</p>
      </div>
      <div class="consent-card">
        <div class="consent-card-header">
          <h3>Our Services</h3>
          <div class="initials-box-wrap">
            <span class="initials-label">Initials:</span>
            <input type="text" class="initials-box name-initials-field" name="init_services" readonly />
          </div>
        </div>
        <div class="consent-body">
          <p><strong>Psychiatric Rehabilitation (PRP):</strong> The PRP program helps you develop or maintain life skills and community connections. Services support physical, emotional, social, and behavioral health and development, and help you improve your ability to communicate and socialize.</p>
          <p><strong>Crisis Services:</strong> During regular office hours, call the office and ask to speak to your provider if you're in crisis. If your counselor is unavailable, another staff member will assist you.</p>
          <div class="crisis-box">
            <strong>Crisis Lines:</strong>
            <ul>
              <li>988 Suicide &amp; Crisis Lifeline: Call or text 988</li>
              <li>Baltimore City Crisis: 410-433-5175</li>
              <li>Maryland Crisis Hotline: 800-422-0009</li>
              <li>National Suicide Prevention: 1-800-273-8255</li>
            </ul>
          </div>
        </div>
        <label class="ack-check required-field"><input type="checkbox" name="ack_services" required /> I have read and understand the information about Our Services.</label>
      </div>
    </div>

    <!-- =================== SECTION 12: CONSENT — PARTICIPATION + ATTENDANCE =================== -->
    <div class="form-section" id="s12" data-label="Consent — Participation">
      <div class="section-header">
        <div class="section-icon">🤝</div>
        <h2>Participation &amp; Attendance</h2>
      </div>
      <div class="consent-card">
        <div class="consent-card-header">
          <h3>Voluntary Participation</h3>
          <div class="initials-box-wrap"><span class="initials-label">Initials:</span><input type="text" class="initials-box name-initials-field" name="init_participation" readonly /></div>
        </div>
        <div class="consent-body">
          <p>All clients voluntarily agree to treatment and may stop at any time without penalty. If you feel the program isn't a good fit, your therapist will help connect you with another clinician.</p>
        </div>
        <label class="ack-check required-field"><input type="checkbox" name="ack_participation" required /> I understand my participation is fully voluntary.</label>
      </div>
      <div class="consent-card" style="margin-top: var(--spacing-3);">
        <div class="consent-card-header">
          <h3>Attendance &amp; Missed Appointments</h3>
          <div class="initials-box-wrap"><span class="initials-label">Initials:</span><input type="text" class="initials-box name-initials-field" name="init_attendance" readonly /></div>
        </div>
        <div class="consent-body">
          <p>Please attend all scheduled sessions. If you need to cancel, give at least 24 hours' notice. After 3 missed appointments without notice, we may not be able to hold your spot. We want to work with you — please reach out if something comes up.</p>
        </div>
        <label class="ack-check required-field"><input type="checkbox" name="ack_attendance" required /> I understand the attendance and cancellation policy.</label>
      </div>
    </div>

    <!-- =================== SECTION 13: CONSENT — CONFIDENTIALITY + PRIVACY =================== -->
    <div class="form-section" id="s13" data-label="Consent — Privacy">
      <div class="section-header">
        <div class="section-icon">🔒</div>
