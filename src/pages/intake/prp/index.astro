  }

  .ack-check input { width: 16px; height: 16px; accent-color: var(--prp-accent); flex-shrink: 0; margin-top: 1px; }

  /* ===== UPLOAD ===== */
  .upload-zone {
    position: relative;
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    text-align: center;
    transition: all 0.2s;
    background: white;
    overflow: hidden;
  }

  .upload-zone:hover { border-color: var(--prp-accent); background: var(--prp-accent-light); }

  .upload-zone.uploaded { border-color: var(--success); border-style: solid; }

  .upload-zone-inner { padding: 36px 24px; pointer-events: none; }

  .upload-zone svg { color: var(--muted); margin-bottom: 10px; transition: color 0.2s; }
  .upload-zone:hover svg { color: var(--prp-accent); }
  .upload-zone.uploaded svg { color: var(--success); }

  .upload-title { font-weight: 700; font-size: 0.98rem; color: var(--text); margin: 0 0 4px; }
  .upload-hint { font-size: 0.78rem; color: var(--muted); }

  .upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-success {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--success);
  }

  /* ===== MEDICATION TABLE ===== */
  .med-table-wrap { overflow-x: auto; border-radius: var(--radius-sm); border: 1px solid var(--border); }

  .med-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .med-table th { background: #f1f5f9; padding: 8px 10px; text-align: left; font-size: 0.73rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); border-bottom: 1px solid var(--border); white-space: nowrap; }
  .med-table td { padding: 6px; border-bottom: 1px solid var(--border); }
  .med-table tr:last-child td { border-bottom: none; }
  .med-table input, .med-table select { width: 100%; padding: 6px 8px; border: 1px solid var(--border); border-radius: 6px; font-size: 0.85rem; font-family: inherit; background: white; }

  .btn-add-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    background: none;
    border: 1.5px dashed var(--border);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-add-row:hover { border-color: var(--prp-accent); color: var(--prp-accent); }

  /* ===== REVIEW ===== */
  .review-card { padding: 0; overflow: hidden; }
  .review-row { display: flex; padding: 12px 20px; border-bottom: 1px solid var(--border); gap: 16px; align-items: center; }
  .review-row:last-child { border-bottom: none; }
  .review-lbl { font-size: 0.82rem; font-weight: 700; color: var(--muted); min-width: 140px; }
  .review-val { font-size: 0.92rem; color: var(--text); font-weight: 500; }

  .sig-title { font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 12px; }
  .sig-divider { border: none; border-top: 1px solid var(--border); margin: 16px 0; }
  .sig-note { font-size: 0.82rem; color: var(--muted); margin-bottom: 10px; }

  /* ===== HEADINGS ===== */
  .sub-heading { font-size: 0.88rem; font-weight: 800; color: var(--text); margin: 16px 0 8px; text-transform: uppercase; letter-spacing: 0.03em; }

  /* ===== BOTTOM NAV ===== */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: white;
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.07);
    z-index: 100;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 40px;
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .nav-back {
    background: #f1f5f9;
    color: var(--muted);
  }
  .nav-back:hover { background: #e2e8f0; color: var(--text); }

  .nav-next {
    background: var(--prp-accent);
    color: white;
    box-shadow: 0 4px 14px rgba(27,79,114,0.3);
  }
  .nav-next:hover { background: #154360; box-shadow: 0 6px 20px rgba(27,79,114,0.4); transform: translateY(-1px); }

  /* ===== SUBMIT ===== */
  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 15px;
    border-radius: 40px;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    border: none;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: white;
    box-shadow: 0 4px 20px rgba(22,163,74,0.3);
    margin-top: 20px;
    transition: all 0.2s;
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(22,163,74,0.4); }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  /* ===== ERROR BANNER ===== */
  .error-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 10px;
    padding: 12px 16px;
    color: #991b1b;
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 16px;
  }

  /* ===== SUCCESS ===== */
  .success-ring {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: rgba(22,163,74,0.1);
    color: var(--success);
    margin-bottom: 8px;
  }

  /* ===== SPIN ===== */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .spin { animation: spin 0.9s linear infinite; }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('astro:page-load', () => {
    const TOTAL_SECTIONS = 21; // s1 through s21
    let current = 1;

    const nameInput = document.getElementById('fullname');
    const dobInput = document.getElementById('dob');

    // ---- AUTO-POPULATE ----
    function initials(name) {
      const parts = (name || '').trim().split(/\s+/).filter(Boolean);
      if (!parts.length) return '';
      const first = parts[0][0]?.toUpperCase();
      const last = parts.length > 1 ? parts[parts.length - 1][0]?.toUpperCase() : '';
      return last ? `${first}.${last}.` : `${first}.`;
    }

    function populate() {
      const name = nameInput?.value || '';
      const dob = dobInput?.value || '';
      const ini = initials(name);
      const today = new Date().toISOString().split('T')[0];

      document.querySelectorAll('.name-initials-field').forEach(el => el.value = ini);

      // Name fields
      ['fs_name','consent_name','consent_dob','roi_name','roi_dob','roi_signature','roi_sigDate',
       'carelon_name','carelon_dob','carelon_sig','carelon_sigDate',
       'ciq_clientName','ciq_dob','ciq_today','finalSignature'].forEach(n => {
        const els = document.querySelectorAll(`[name="${n}"]`);
        els.forEach(el => {
          if (n.includes('name') || n.includes('Name') || n.includes('signature') || n.includes('sig') && !n.includes('date') && !n.includes('Date')) {
            if (n.toLowerCase().includes('dob') || n.toLowerCase().includes('date') || n === 'ciq_today') {
              el.value = n === 'ciq_today' ? today : (n.toLowerCase().includes('dob') ? dob : today);
            } else {
              el.value = name;
            }
          }
        });
      });

      // All name auto-fill fields
      document.querySelectorAll('.autofill-input:not([type="date"])').forEach(el => {
        if (!el.value || el.value === '') el.value = name;
      });

      // Signature fields
      document.querySelectorAll('.signature-style').forEach(el => { el.value = name; });

      // Date auto-fill
      document.querySelectorAll('.today-field, [name$="_date"], [name$="Date"], [name$="_sigDate"]').forEach(el => {
        if (el.readOnly && el.type === 'date') el.value = today;
      });

      // DOB auto-fill
      document.querySelectorAll('[name$="_dob"], [name$="Dob"]').forEach(el => {
        if (el.readOnly) el.value = dob;
      });
    }

    nameInput?.addEventListener('input', populate);
    dobInput?.addEventListener('change', populate);
    populate();

    // ---- PROGRESS ----
    function setProgress(step) {
      const pct = Math.round(((step - 1) / (TOTAL_SECTIONS - 1)) * 100);
      const fill = document.getElementById('progress-fill');
      const pctDisp = document.getElementById('pct-display');
      if (fill) fill.style.width = pct + '%';
      if (pctDisp) pctDisp.textContent = pct + '%';
    }

    function showSection(n) {
      document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
      const target = document.getElementById(`s${n}`);
      if (target) target.classList.add('active');

      const meta = document.getElementById('section-meta');
      const label = target?.dataset.label || '';
      if (meta) meta.innerHTML = `Section ${n} of ${TOTAL_SECTIONS} &mdash; <span>${label}</span>`;

      // Back button visibility
      const backBtn = document.getElementById('btn-back');
      if (backBtn) backBtn.style.visibility = n === 1 ? 'hidden' : 'visible';

      // Hide bottom nav on last step
      const bottomNav = document.getElementById('bottom-nav');
      if (bottomNav) bottomNav.style.display = n === TOTAL_SECTIONS ? 'none' : 'flex';

      setProgress(n);
      current = n;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ---- VALIDATION ----
    function validateCurrent() {
      const section = document.getElementById(`s${current}`);
      if (!section) return true;
      let valid = true;

      // Required text/date/tel inputs
      section.querySelectorAll('input[required], select[required]').forEach(input => {
        const errEl = document.getElementById(`err-${input.id}`);
        if (!input.value.trim()) {
          input.setAttribute('aria-invalid', 'true');
          input.style.borderColor = '#dc2626';
          if (errEl) { errEl.style.display = 'block'; }
          valid = false;
        } else {
          input.removeAttribute('aria-invalid');
          input.style.borderColor = '';
          if (errEl) { errEl.style.display = 'none'; }
        }
      });

      // Required file inputs
      section.querySelectorAll('input[type="file"][required]').forEach(input => {
        const errEl = document.getElementById(`err-${input.id}`);
        if (!input.files?.length) {
          const zone = input.closest('.upload-zone');
          if (zone) zone.style.borderColor = '#dc2626';
          if (errEl) { errEl.style.display = 'block'; }
          valid = false;
        } else {
          const zone = input.closest('.upload-zone');
          if (zone) zone.style.borderColor = '';
          if (errEl) { errEl.style.display = 'none'; }
        }
      });

      // Required checkboxes in ack-check
      section.querySelectorAll('.ack-check.required-field input[type="checkbox"]').forEach(cb => {
        const ack = cb.closest('.ack-check');
        if (!cb.checked) {
          if (ack) { ack.style.borderColor = '#dc2626'; ack.style.background = '#fef2f2'; }
          valid = false;
        } else {
          if (ack) { ack.style.borderColor = ''; ack.style.background = ''; }
        }
      });

      if (!valid) {
        const first = section.querySelector('[aria-invalid="true"], .upload-zone[style*="dc2626"]');
        first?.scrollIntoView?.({ behavior: 'smooth', block: 'center' });
      }
      return valid;
    }

    // ---- NAVIGATION ----
    document.getElementById('btn-next')?.addEventListener('click', () => {
      if (!validateCurrent()) return;
      populate();
      updateReview();
      if (current < TOTAL_SECTIONS) showSection(current + 1);
    });

    document.getElementById('btn-back')?.addEventListener('click', () => {
      if (current > 1) showSection(current - 1);
    });

    // ---- UPLOADS ----
    function setupUpload(inputId, zoneId, successId, filenameId) {
      const input = document.getElementById(inputId);
      const zone = document.getElementById(zoneId);
      const success = document.getElementById(successId);
      if (!input || !zone) return;
      input.addEventListener('change', () => {
        const file = input.files?.[0];
        if (file) {
          zone.classList.add('uploaded');
          zone.querySelector('.upload-title').textContent = '✓ ' + file.name;
          if (success) success.style.display = 'flex';
          const fnEl = document.getElementById(filenameId);
          if (fnEl) fnEl.textContent = file.name;
          const errEl = document.getElementById(`err-${inputId}`);
          if (errEl) errEl.style.display = 'none';
        }
      });
    }

    setupUpload('gov-id', 'govid-zone', 'govid-success', 'govid-filename');
    setupUpload('insurance-card', 'insurance-zone', 'insurance-success', 'insurance-filename');

    // ---- CONDITIONAL FIELDS ----
    document.querySelector('input[name="hasBenefits"]')?.closest('.field-group')
      ?.querySelectorAll('input[name="hasBenefits"]').forEach(r => {
        r.addEventListener('change', () => {
          const d = document.getElementById('benefits-detail');
          if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
        });
      });

    document.querySelectorAll('input[name="hasPCP"]').forEach(r => {
      r.addEventListener('change', () => {
        const d = document.getElementById('pcp-fields');
        if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
      });
    });

    // Communication checkboxes
    document.getElementById('comm-email-check')?.addEventListener('change', function() {
      const a = document.getElementById('comm-email-addr');
      if (a) a.style.display = this.checked ? 'inline-block' : 'none';
    });
    document.getElementById('comm-text-check')?.addEventListener('change', function() {
      const a = document.getElementById('comm-text-num');
      if (a) a.style.display = this.checked ? 'inline-block' : 'none';
    });

    // Minor section
    document.getElementById('is-adult')?.addEventListener('change', function() {
      const gf = document.getElementById('guardian-fields');
      if (gf) gf.style.display = this.checked ? 'none' : 'block';
    });
    // Default hide
    const guardianFields = document.getElementById('guardian-fields');
    if (guardianFields) guardianFields.style.display = 'none';

    // ---- MED TABLE ----
    let medCount = 1;
    document.getElementById('add-med')?.addEventListener('click', () => {
      const body = document.getElementById('med-body');
      const i = medCount++;
      const row = document.createElement('tr');
      row.innerHTML = `<td><input type="text" name="meds[${i}][name]" placeholder="Medication" /></td><td><input type="text" name="meds[${i}][dose]" /></td><td><input type="text" name="meds[${i}][prescriber]" /></td><td><input type="date" name="meds[${i}][startDate]" /></td><td><button type="button" onclick="this.closest('tr').remove()" style="background:none;border:none;cursor:pointer;color:#dc2626;font-size:1rem;padding:4px;">✕</button></td>`;
      body?.appendChild(row);
    });

    // ---- REVIEW ----
    function updateReview() {
      const name = nameInput?.value || '—';
      const dob = dobInput?.value || '—';
      const emgN = document.querySelector('[name="emergencyContactName"]')?.value || '—';
      const emgP = document.querySelector('[name="emergencyContactPhone"]')?.value || '';
      const gid = document.getElementById('gov-id');
      const ins = document.getElementById('insurance-card');

      const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
      set('rv-name', name);
      set('rv-dob', dob);
      set('rv-emg', emgN + (emgP ? ` — ${emgP}` : ''));
      set('rv-govid', gid?.files?.[0]?.name || 'Not uploaded');
      set('rv-insurance', ins?.files?.[0]?.name || 'Not uploaded');
    }

    // ---- SUBMIT ----
    document.getElementById('prp-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateCurrent()) return;

      const btn = document.getElementById('submit-btn');
      const errBanner = document.getElementById('form-error-banner');
      const errText = document.getElementById('error-msg-text');

      btn.disabled = true;
      btn.innerHTML = `<svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Submitting...`;

      try {
        const fd = new FormData(document.getElementById('prp-form'));
        fd.set('program', 'PRP');
        const baseUrl = (window.__ENV__ || {}).PUBLIC_SUPABASE_URL || '';
        if (!baseUrl) throw new Error('Config error — please contact support');
        const res = await fetch(`${baseUrl}/functions/v1/intake-submit`, { method: 'POST', body: fd });
        if (!res.ok) { const err = await res.json().catch(() => ({})); throw new Error(err.error || `Error ${res.status}`); }

        document.querySelectorAll('.form-section').forEach(s => s.style.display = 'none');
        document.getElementById('s-success').style.display = 'block';
        document.getElementById('bottom-nav').style.display = 'none';
        document.getElementById('progress-fill').style.width = '100%';
        document.getElementById('pct-display').textContent = '100%';
        window.scrollTo({ top: 0, behavior: 'smooth' });

      } catch (err) {
        if (errBanner) errBanner.style.display = 'flex';
        if (errText) errText.textContent = err.message;
        btn.disabled = false;
        btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Submit My PRP Intake`;
      }
    });

    // Initialize
    showSection(1);
  });
</script>

</Layout>
