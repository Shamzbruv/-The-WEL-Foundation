---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Start Your Intake — The WEL Foundation">
  <div class="container" style="padding: var(--spacing-8) 0; max-width: 960px; text-align: center;">
    <div class="reveal-on-scroll" style="margin-bottom: var(--spacing-3);">
      <span style="background-color: rgba(13,27,42,0.07); border: 1px solid rgba(13,27,42,0.12); border-radius: 40px; padding: 0.4rem 1.2rem; font-size: 0.8rem; font-weight: 600; color: var(--color-primary-navy); letter-spacing: 0.06em; text-transform: uppercase;">Confidential & Secure</span>
    </div>

    <h1 class="reveal-on-scroll stagger-1" style="font-size: clamp(2.2rem, 5vw, 3.2rem); margin-bottom: var(--spacing-3); letter-spacing: -0.02em;">
      Ready to Take the First Step?
    </h1>
    <p class="reveal-on-scroll stagger-2" style="font-size: 1.1rem; color: var(--color-text-muted); max-width: 640px; margin: 0 auto var(--spacing-8); line-height: 1.7;">
      Choose your program below to start your intake form. It only takes about 10–15 minutes. Everything you share is private and protected.
    </p>

    <!-- Program Selection Cards -->
    <div class="program-cards reveal-on-scroll stagger-3">

      <!-- PRP Card -->
      <a href="/intake/prp/" class="program-card prp-card" id="prp-intake-link" aria-label="Start PRP Intake Form">
        <div class="program-card-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <div class="program-card-label">PRP</div>
        <h2 class="program-card-title">Psychiatric Rehabilitation</h2>
        <p class="program-card-desc">
          This program helps you build daily life skills, connect with your community, and strengthen your mental health — at your own pace.
        </p>
        <div class="program-card-cta">
          Start PRP Intake
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
      </a>

      <!-- SUD Card -->
      <a href="/intake/sud/" class="program-card sud-card" id="sud-intake-link" aria-label="Start SUD Intake Form">
        <div class="program-card-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="M12 8v4"/>
            <path d="M12 16h.01"/>
          </svg>
        </div>
        <div class="program-card-label">SUD</div>
        <h2 class="program-card-title">Substance Use Disorder</h2>
        <p class="program-card-desc">
          This program provides counseling, group support, and recovery tools to help you take back control and move forward in life.
        </p>
        <div class="program-card-cta">
          Start SUD Intake
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
      </a>

    </div>

    <!-- What to Have Ready -->
    <div class="reveal-on-scroll" style="margin-top: var(--spacing-8); background-color: var(--color-bg-offset, #f8fafc); border: 1px solid var(--color-border); border-radius: var(--radius-md, 12px); padding: var(--spacing-5); text-align: left; max-width: 600px; margin-inline: auto; margin-top: var(--spacing-8);">
      <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-primary-navy); margin-bottom: var(--spacing-3); display: flex; align-items: center; gap: 8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Have these ready before you start:
      </h3>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--spacing-2);">
        <li class="checklist-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-gold-muted, #b45309)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          A photo or scan of your <strong>government-issued ID</strong> (driver's license, state ID, passport)
        </li>
        <li class="checklist-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-gold-muted, #b45309)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          A photo or scan of your <strong>insurance card</strong> (Medicaid, Medicare, or private)
        </li>
        <li class="checklist-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-gold-muted, #b45309)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Your <strong>emergency contact's</strong> name and phone number
        </li>
        <li class="checklist-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-gold-muted, #b45309)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Your <strong>primary doctor's</strong> name and phone number (if you have one)
        </li>
      </ul>
    </div>

    <p style="margin-top: var(--spacing-5); font-size: 0.85rem; color: var(--color-text-muted);">
      🔒 Your information is encrypted and kept completely private.
    </p>

  </div>

  <style>
    .program-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--spacing-5);
      max-width: 780px;
      margin-inline: auto;
    }

    .program-card {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      text-decoration: none;
      padding: var(--spacing-6);
      border-radius: var(--radius-lg, 16px);
      border: 2px solid transparent;
      background: var(--color-bg-surface, #fff);
      box-shadow: 0 2px 16px rgba(13,27,42,0.07);
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      cursor: pointer;
    }

    .program-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 40px rgba(13,27,42,0.14);
    }

    .prp-card:hover { border-color: var(--color-primary-blue, #1B4F72); }
    .sud-card:hover { border-color: var(--color-accent-gold-muted, #b45309); }

    .program-card-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 60px;
      height: 60px;
      border-radius: 14px;
      margin-bottom: var(--spacing-4);
    }

    .prp-card .program-card-icon {
      background: rgba(27, 79, 114, 0.1);
      color: var(--color-primary-blue, #1B4F72);
    }

    .sud-card .program-card-icon {
      background: rgba(180, 83, 9, 0.1);
      color: var(--color-accent-gold-muted, #b45309);
    }

    .program-card-label {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: var(--spacing-1);
    }

    .prp-card .program-card-label { color: var(--color-primary-blue, #1B4F72); }
    .sud-card .program-card-label { color: var(--color-accent-gold-muted, #b45309); }

    .program-card-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--color-primary-navy, #0F172A);
      margin-bottom: var(--spacing-3);
      line-height: 1.2;
    }

    .program-card-desc {
      font-size: 0.95rem;
      color: var(--color-text-secondary, #64748b);
      line-height: 1.6;
      flex-grow: 1;
      margin-bottom: var(--spacing-5);
    }

    .program-card-cta {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .prp-card .program-card-cta { color: var(--color-primary-blue, #1B4F72); }
    .sud-card .program-card-cta { color: var(--color-accent-gold-muted, #b45309); }

    .checklist-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.92rem;
      color: var(--color-text-secondary, #475569);
      line-height: 1.5;
    }

    .checklist-item svg {
      flex-shrink: 0;
      margin-top: 3px;
    }
  </style>
</Layout>
