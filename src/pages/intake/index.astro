---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Client Intake">
  <div class="container" style="padding: var(--spacing-6) 0; max-width: 800px; text-align: center;">
    <h1 style="color: var(--color-primary-blue); font-size: 2.5rem; margin-bottom: var(--spacing-4);">Client Intake Application</h1>
    <p style="font-size: 1.1rem; margin-bottom: var(--spacing-6); color: var(--color-text-muted);">
      Welcome to your first step toward recovery and empowerment. All information submitted here is treated with strict confidentiality.
    </p>

    <div class="card" style="text-align: left; margin-bottom: var(--spacing-6);">
      <h2 style="margin-bottom: var(--spacing-3);">What to Expect</h2>
      <ul style="margin-bottom: var(--spacing-4); padding-left: var(--spacing-4);">
        <li style="margin-bottom: var(--spacing-2);">You will need a valid copy of your state-issued Government ID.</li>
        <li style="margin-bottom: var(--spacing-2);">You will need your current Insurance credentials (if applicable).</li>
        <li style="margin-bottom: var(--spacing-2);">Expect the process to take approximately 5-10 minutes.</li>
        <li style="margin-bottom: var(--spacing-2);">Once submitted, our team targets a 3-business-day turnaround for review.</li>
      </ul>
      <div style="text-align: center; margin-top: var(--spacing-6);">
        <a href="/intake/start/" class="btn" style="padding: 1rem 2rem; font-size: 1.1rem;">Begin Secure Intake</a>
      </div>
    </div>
  </div>
</Layout>
