        <h3 class="sig-title">Final Signature</h3>
        <p style="font-size:0.88rem; color:var(--muted); margin-bottom:12px;">By submitting, you confirm all information is accurate and complete.</p>
        <div class="field-row-2">
          <div class="field-group"><label class="field-label autofill-label">Signature <span class="autofill-tag">Auto</span></label><input class="field-input autofill-input signature-style" type="text" name="finalSignature" readonly /></div>
          <div class="field-group"><label class="field-label autofill-label">Date <span class="autofill-tag">Auto</span></label><input class="field-input autofill-input" type="date" name="finalDate" readonly /></div>
        </div>
      </div>
      <div id="form-error-banner" class="error-banner" style="display:none;" role="alert">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span id="error-msg-text">Something went wrong. Please try again.</span>
      </div>
      <button type="submit" class="btn-submit" id="submit-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Submit My SUD Intake
      </button>
