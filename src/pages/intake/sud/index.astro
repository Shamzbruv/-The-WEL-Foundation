<script>
  // @ts-nocheck
  document.addEventListener('astro:page-load', () => {
    const TOTAL = 26;
    let current = 1;

    const nameInput = document.getElementById('fullname');
    const dobInput = document.getElementById('dob');

    function initials(name) {
      const parts = (name || '').trim().split(/\s+/).filter(Boolean);
      if (!parts.length) return '';
      const f = parts[0][0]?.toUpperCase();
      const l = parts.length > 1 ? parts[parts.length-1][0]?.toUpperCase() : '';
      return l ? `${f}.${l}.` : `${f}.`;
    }

    function populate() {
      const name = nameInput?.value || '';
      const dob = dobInput?.value || '';
      const ini = initials(name);
      const today = new Date().toISOString().split('T')[0];

      document.querySelectorAll('.name-initials-field').forEach(el => el.value = ini);
      document.querySelectorAll('.signature-style').forEach(el => { if (el.readOnly) el.value = name; });
      document.querySelectorAll('.autofill-input:not([type="date"])').forEach(el => {
        if (el.readOnly && !el.classList.contains('signature-style')) el.value = name;
      });
      document.querySelectorAll('.autofill-input[type="date"]').forEach(el => {
        if (el.readOnly) {
          const n = el.name || '';
          if (n.toLowerCase().includes('dob')) el.value = dob;
          else el.value = today;
        }
      });
    }

    nameInput?.addEventListener('input', populate);
    dobInput?.addEventListener('change', populate);
    populate();

    function setProgress(step) {
      const pct = Math.round(((step-1)/(TOTAL-1))*100);
      const fill = document.getElementById('progress-fill');
      const disp = document.getElementById('pct-display');
      if (fill) fill.style.width = pct + '%';
      if (disp) disp.textContent = pct + '%';
    }

    function showSection(n) {
      document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
      const t = document.getElementById(`s${n}`);
      if (t) t.classList.add('active');
      const meta = document.getElementById('section-meta');
      if (meta) meta.innerHTML = `Section ${n} of ${TOTAL} &mdash; <span>${t?.dataset.label||''}</span>`;
      const back = document.getElementById('btn-back');
      if (back) back.style.visibility = n === 1 ? 'hidden' : 'visible';
      const nav = document.getElementById('bottom-nav');
      if (nav) nav.style.display = n === TOTAL ? 'none' : 'flex';
      setProgress(n);
      current = n;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function validateCurrent() {
      const section = document.getElementById(`s${current}`);
      if (!section) return true;
      let valid = true;

      section.querySelectorAll('input[required], select[required]').forEach(input => {
        const errEl = document.getElementById(`err-${input.id}`);
        if (!input.value.trim()) {
          input.setAttribute('aria-invalid','true');
          input.style.borderColor = '#dc2626';
          if (errEl) errEl.style.display = 'block';
          valid = false;
        } else {
          input.removeAttribute('aria-invalid');
          input.style.borderColor = '';
          if (errEl) errEl.style.display = 'none';
        }
      });

      section.querySelectorAll('input[type="file"][required]').forEach(input => {
        const errEl = document.getElementById(`err-${input.id}`);
        if (!input.files?.length) {
          const zone = input.closest('.upload-zone');
          if (zone) zone.style.borderColor = '#dc2626';
          if (errEl) errEl.style.display = 'block';
          valid = false;
        } else {
          const zone = input.closest('.upload-zone');
          if (zone) zone.style.borderColor = '';
          if (errEl) errEl.style.display = 'none';
        }
      });

      section.querySelectorAll('.ack-check.required-field input[type="checkbox"]').forEach(cb => {
        const ack = cb.closest('.ack-check');
        if (!cb.checked) {
          if (ack) { ack.style.borderColor = '#dc2626'; ack.style.background = '#fef2f2'; }
          valid = false;
        } else {
          if (ack) { ack.style.borderColor = ''; ack.style.background = ''; }
        }
      });

      if (!valid) {
        const first = section.querySelector('[aria-invalid="true"]');
        first?.scrollIntoView?.({ behavior: 'smooth', block: 'center' });
      }
      return valid;
    }

    document.getElementById('btn-next')?.addEventListener('click', () => {
      if (!validateCurrent()) return;
      populate();
      updateReview();
      if (current < TOTAL) showSection(current + 1);
    });

    document.getElementById('btn-back')?.addEventListener('click', () => {
      if (current > 1) showSection(current - 1);
    });

    // Uploads
    function setupUpload(inputId, zoneId, successId, filenameId) {
      const input = document.getElementById(inputId);
      const zone = document.getElementById(zoneId);
      const success = document.getElementById(successId);
      if (!input || !zone) return;
      input.addEventListener('change', () => {
        const file = input.files?.[0];
        if (file) {
          zone.classList.add('uploaded');
          zone.querySelector('.upload-title').textContent = '✓ ' + file.name;
          if (success) success.style.display = 'flex';
          const fn = document.getElementById(filenameId);
          if (fn) fn.textContent = file.name;
          const e = document.getElementById(`err-${inputId}`);
          if (e) e.style.display = 'none';
        }
      });
    }

    setupUpload('gov-id','govid-zone','govid-success','govid-filename');
    setupUpload('insurance-card','insurance-zone','insurance-success','insurance-filename');

    // Conditionals
    document.querySelectorAll('input[name="hasPCP"]').forEach(r => r.addEventListener('change', () => {
      const d = document.getElementById('pcp-fields');
      if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
    }));

    document.querySelectorAll('input[name="isOnMAT"]').forEach(r => r.addEventListener('change', () => {
      const d = document.getElementById('mat-dose');
      if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
    }));

    document.querySelectorAll('input[name="everIncarcerated"]').forEach(r => r.addEventListener('change', () => {
      const d = document.getElementById('incarceration-when');
      if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
    }));

    const paroleCheck = document.getElementById('parole-check');
    const probationCheck = document.getElementById('probation-check');
    const agentSection = document.getElementById('agent-section');

    function updateAgentSection() {
      if (agentSection) agentSection.style.display = (paroleCheck?.checked || probationCheck?.checked) ? 'block' : 'none';
    }
    paroleCheck?.addEventListener('change', updateAgentSection);
    probationCheck?.addEventListener('change', updateAgentSection);

    document.querySelectorAll('input[name="pendingCharges"]').forEach(r => r.addEventListener('change', () => {
      const d = document.getElementById('pending-charges-detail');
      if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
    }));

    document.querySelectorAll('input[name="hasCrisis"]').forEach(r => r.addEventListener('change', () => {
      const d = document.getElementById('crisis-detail');
      if (d) d.style.display = r.value === 'yes' ? 'block' : 'none';
    }));

    document.getElementById('is-adult')?.addEventListener('change', function() {
      const gf = document.getElementById('guardian-fields');
      if (gf) gf.style.display = this.checked ? 'none' : 'block';
    });

    document.getElementById('comm-email-check')?.addEventListener('change', function() {
      const a = document.getElementById('comm-email-addr');
      if (a) a.style.display = this.checked ? 'inline-block' : 'none';
    });
    document.getElementById('comm-text-check')?.addEventListener('change', function() {
      const a = document.getElementById('comm-text-num');
      if (a) a.style.display = this.checked ? 'inline-block' : 'none';
    });

    // Med table
    let medCount = 1;
    document.getElementById('add-med')?.addEventListener('click', () => {
      const body = document.getElementById('med-body');
      const i = medCount++;
      const row = document.createElement('tr');
      row.innerHTML = `<td><input type="text" name="meds[${i}][name]" /></td><td><input type="text" name="meds[${i}][dose]" /></td><td><input type="text" name="meds[${i}][prescriber]" /></td><td><input type="date" name="meds[${i}][startDate]" /></td><td><button type="button" onclick="this.closest('tr').remove()" style="background:none;border:none;cursor:pointer;color:#dc2626;font-size:1rem;padding:4px;">✕</button></td>`;
      body?.appendChild(row);
    });

    let drugCount = 1;
    document.getElementById('add-drug')?.addEventListener('click', () => {
      const body = document.getElementById('drug-body');
      const i = drugCount++;
      const row = document.createElement('tr');
      row.innerHTML = `<td><input type="text" name="drugs[${i}][name]" /></td><td><select name="drugs[${i}][severity]"><option value="">Select...</option><option>Mild</option><option>Moderate</option><option>Severe</option></select></td><td><select name="drugs[${i}][route]"><option value="">Select...</option><option>Inject</option><option>Smoke</option><option>Snort</option><option>Oral</option><option>Other</option></select></td><td><input type="number" name="drugs[${i}][ageFirst]" min="1" max="100" /></td><td><input type="date" name="drugs[${i}][lastUsed]" /></td><td><button type="button" onclick="this.closest('tr').remove()" style="background:none;border:none;cursor:pointer;color:#dc2626;font-size:1rem;padding:4px;">✕</button></td>`;
      body?.appendChild(row);
    });

    function updateReview() {
      const name = nameInput?.value || '—';
      const dob = dobInput?.value || '—';
      const emgN = document.querySelector('[name="emergencyContactName"]')?.value || '—';
      const emgP = document.querySelector('[name="emergencyContactPhone"]')?.value || '';
      const gid = document.getElementById('gov-id');
      const ins = document.getElementById('insurance-card');
      const set = (id,v) => { const el=document.getElementById(id); if(el) el.textContent=v; };
      set('rv-name', name);
      set('rv-dob', dob);
      set('rv-emg', emgN + (emgP ? ` — ${emgP}` : ''));
      set('rv-govid', gid?.files?.[0]?.name || 'Not uploaded');
      set('rv-insurance', ins?.files?.[0]?.name || 'Not uploaded');
    }

    document.getElementById('sud-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateCurrent()) return;
      const btn = document.getElementById('submit-btn');
      const errBanner = document.getElementById('form-error-banner');
      const errText = document.getElementById('error-msg-text');
      btn.disabled = true;
      btn.innerHTML = `<svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Submitting...`;
      try {
        const fd = new FormData(document.getElementById('sud-form'));
        fd.set('program', 'SUD');
        // Use Astro's build-time env (correct pattern — window.__ENV__ is not defined)
        const baseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
        if (!baseUrl) throw new Error('Configuration unavailable — please call us at 443-826-2770.');
        const res = await fetch(`${baseUrl}/functions/v1/intake-submit`, { method: 'POST', body: fd });
        if (!res.ok) { const err = await res.json().catch(() => ({})); throw new Error(err.error || `Error ${res.status}`); }
        document.querySelectorAll('.form-section').forEach(s => s.style.display = 'none');
        document.getElementById('s-success').style.display = 'block';
        document.getElementById('bottom-nav').style.display = 'none';
        document.getElementById('progress-fill').style.width = '100%';
        document.getElementById('pct-display').textContent = '100%';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err) {
        if (errBanner) errBanner.style.display = 'flex';
        if (errText) errText.textContent = "We couldn't send your form just yet. Nothing was lost — please try again, or call us at 443-826-2770 for help.";
        btn.disabled = false;
        btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Submit form`;
      }
    });

    showSection(1);
  });
</script>

</Layout>
