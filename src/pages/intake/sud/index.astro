    <!-- =================== S23: GAST =================== -->
    <div class="form-section sud-section" id="s23" data-label="Gambling Screen (GAST)">
      <div class="section-header">
        <div class="section-icon">🎲</div>
        <h2>Gamblers Anonymous Screening Test</h2>
        <p>Answer Yes or No for each question about your behavior in the <strong>past 12 months</strong>. If gambling isn't an issue, mark No for all.</p>
        <div class="sud-badge">SUD Section</div>
      </div>
      <div class="gast-list">
        {[
          "Did you ever lose time from work or school due to gambling?",
          "Has gambling ever made your home life unhappy?",
          "Did gambling affect your reputation?",
          "Did you ever gamble to get money to pay debts or solve financial problems?",
          "Did gambling cause a decrease in your ambition or efficiency?",
          "After losing, did you feel you must return as soon as possible to win back losses?",
          "After a win, did you have a strong urge to return and win more?",
          "Did you often gamble until your last dollar was gone?",
          "Did you ever borrow to finance your gambling?",
          "Have you ever sold anything to finance gambling?",
          "Were you reluctant to use \"gambling money\" for normal expenses?",
          "Did gambling make you careless of your welfare or your family's?",
          "Did you ever gamble longer than you had planned?",
          "Have you ever gambled to escape worry or trouble?",
          "Have you ever committed or considered an illegal act to finance gambling?",
          "Did gambling ever cause you difficulty sleeping?",
          "Do arguments, disappointments, or frustrations create an urge to gamble?",
          "Did you ever have an urge to celebrate good fortune by gambling?",
          "Have you ever considered self-destruction or suicide as a result of gambling?"
        ].map((q, i) => (
          <div class="gast-row">
            <span class="gast-num">{i + 1}</span>
            <span class="gast-q">{q}</span>
            <div class="gast-btns">
              <label class="radio-pill sm"><input type="radio" name={`gast_${i}`} value="yes" /> Yes</label>
              <label class="radio-pill sm"><input type="radio" name={`gast_${i}`} value="no" checked /> No</label>
            </div>
          </div>
        ))}
      </div>
    </div>

