---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="SUD Intake Form — The WEL Foundation">

<div class="intake-shell">

  <!-- Sticky Top Bar -->
  <div class="intake-topbar">
    <a href="/intake/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back
    </a>
    <div class="topbar-badge">SUD — Substance Use Disorder</div>
    <div class="topbar-pct" id="pct-display">0%</div>
  </div>

  <!-- Progress Bar -->
  <div class="progress-rail">
    <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
  </div>

  <!-- Section Counter -->
  <div class="section-meta" id="section-meta">Section 1 of 26 &mdash; <span id="section-label-text">Your Name</span></div>

  <form id="sud-form" novalidate>

    <!-- =================== S1: NAME =================== -->
    <div class="form-section active" id="s1" data-label="Your Name">
      <div class="section-header">
        <div class="section-icon">👤</div>
        <h2>What's your name?</h2>
        <p>We'll use this to fill in your name and initials throughout the form automatically.</p>
      </div>
      <div class="field-group">
        <label class="field-label" for="fullname">Full Legal Name <span class="req">*</span></label>
        <input class="field-input" type="text" id="fullname" name="fullName" placeholder="e.g. John Michael Davis" required autocomplete="name" />
        <div class="field-error" id="err-fullname">Please enter your full name.</div>
      </div>
      <div class="field-group">
        <label class="field-label" for="dob">Date of Birth <span class="req">*</span></label>
        <input class="field-input" type="date" id="dob" name="dateOfBirth" required />
        <div class="field-error" id="err-dob">Please enter your date of birth.</div>
      </div>
      <div class="field-group">
        <label class="field-label" for="ssn">Social Security # <span class="field-opt">(optional)</span></label>
        <input class="field-input" type="text" id="ssn" name="ssn" placeholder="XXX-XX-XXXX" autocomplete="off" />
      </div>
    </div>

    <!-- =================== S2: GOV ID =================== -->
    <div class="form-section" id="s2" data-label="Government ID">
      <div class="section-header">
        <div class="section-icon">🪪</div>
        <h2>Upload your Government ID</h2>
        <p>Driver's license, state ID, or passport. You can take a photo on your phone.</p>
      </div>
      <div class="upload-zone" id="govid-zone">
        <input type="file" id="gov-id" name="govId" accept="image/jpeg,image/png,application/pdf" required class="upload-input" />
        <div class="upload-zone-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <p class="upload-title">Tap to upload your ID</p>
          <p class="upload-hint">JPG, PNG, or PDF · Max 10MB</p>
        </div>
      </div>
      <div class="field-error" id="err-gov-id">Please upload your government ID.</div>
      <div class="upload-success" id="govid-success" style="display:none;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="govid-filename">ID uploaded</span>
      </div>
    </div>

    <!-- =================== S3: INSURANCE =================== -->
    <div class="form-section" id="s3" data-label="Insurance Card">
      <div class="section-header">
        <div class="section-icon">🛡️</div>
        <h2>Upload your Insurance Card</h2>
        <p>Medicaid, Medicare, or private insurance — front of the card.</p>
      </div>
      <div class="upload-zone" id="insurance-zone">
        <input type="file" id="insurance-card" name="insuranceCard" accept="image/jpeg,image/png,application/pdf" required class="upload-input" />
        <div class="upload-zone-inner">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p class="upload-title">Tap to upload your insurance card</p>
          <p class="upload-hint">JPG, PNG, or PDF · Max 10MB</p>
        </div>
      </div>
      <div class="field-error" id="err-insurance-card">Please upload your insurance card.</div>
      <div class="upload-success" id="insurance-success" style="display:none;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="insurance-filename">Card uploaded</span>
      </div>
    </div>

    <!-- =================== S4: CONTACT INFO =================== -->
    <div class="form-section" id="s4" data-label="Contact Information">
      <div class="section-header">
        <div class="section-icon">📋</div>
        <h2>Contact Information</h2>
        <p>How we can reach you and where you live.</p>
      </div>
      <div class="autofill-pill">✓ Your name has been filled in automatically</div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Referral Source</label><input class="field-input" type="text" name="referralSource" placeholder="Who referred you?" /></div>
        <div class="field-group"><label class="field-label">Date of Admission</label><input class="field-input" type="date" name="dateOfAdmission" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label autofill-label">Client Name <span class="autofill-tag">Auto</span></label><input class="field-input autofill-input" type="text" name="fs_name" readonly /></div>
        <div class="field-group"><label class="field-label autofill-label">Date of Intake <span class="autofill-tag">Auto</span></label><input class="field-input autofill-input" type="date" name="fs_dateOfIntake" readonly /></div>
      </div>
      <div class="field-group">
        <label class="field-label" for="address">Home Address <span class="req">*</span></label>
        <input class="field-input" type="text" id="address" name="address" required />
        <div class="field-error" id="err-address">Please enter your address.</div>
      </div>
      <div class="field-group">
        <label class="field-label">Are you currently homeless?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="isHomeless" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="isHomeless" value="yes" /> Yes</label></div>
      </div>
      <div class="field-row-3">
        <div class="field-group"><label class="field-label">Cell Phone</label><input class="field-input" type="tel" name="cellPhone" /></div>
        <div class="field-group"><label class="field-label">Home Phone</label><input class="field-input" type="tel" name="homePhone" /></div>
        <div class="field-group"><label class="field-label">Other Phone</label><input class="field-input" type="tel" name="otherPhone" /></div>
      </div>
    </div>

    <!-- =================== S5: PERSONAL INFO =================== -->
    <div class="form-section" id="s5" data-label="Personal Details">
      <div class="section-header">
        <div class="section-icon">🏷️</div>
        <h2>Personal Details</h2>
        <p>Background information to help us provide appropriate care.</p>
      </div>
      <div class="field-row-3">
        <div class="field-group"><label class="field-label">Age</label><input class="field-input" type="number" name="age" min="1" max="120" /></div>
        <div class="field-group"><label class="field-label">Race</label><input class="field-input" type="text" name="race" /></div>
        <div class="field-group"><label class="field-label">Gender Identity</label><input class="field-input" type="text" name="genderIdentity" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Sexual Orientation <span class="field-opt">(optional)</span></label><input class="field-input" type="text" name="sexualOrientation" /></div>
        <div class="field-group"><label class="field-label">Preferred Pronouns <span class="field-opt">(optional)</span></label><input class="field-input" type="text" name="pronouns" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Religious Affiliation <span class="field-opt">(optional)</span></label><input class="field-input" type="text" name="religiousAffiliation" /><label class="checkbox-pill" style="margin-top:5px;"><input type="checkbox" name="religionNA" /> N/A</label></div>
        <div class="field-group"><label class="field-label">Cultural Identity</label><input class="field-input" type="text" name="culturalIdentity" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Highest Grade Completed</label><input class="field-input" type="text" name="educationLevel" /></div>
        <div class="field-group">
          <label class="field-label">Employment Status</label>
          <select class="field-input" name="employmentStatus">
            <option value="">Select...</option>
            <option>Employed full-time</option>
            <option>Employed part-time</option>
            <option>Unemployed / Seeking</option>
            <option>Receiving Public Assistance</option>
            <option>Not applicable</option>
          </select>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Employer (if employed)</label>
        <input class="field-input" type="text" name="employer" placeholder="Employer name" />
        <input class="field-input" type="text" name="employerAddress" placeholder="Employer address" style="margin-top:6px;" />
        <input class="field-input" type="tel" name="employerPhone" placeholder="Employer phone" style="margin-top:6px;" />
      </div>
      <div class="field-group">
        <label class="field-label">Marital Status</label>
        <div class="radio-row flex-wrap">
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="single" /> Single</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="married" /> Married</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="separated" /> Separated</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="divorced" /> Divorced</label>
          <label class="radio-pill"><input type="radio" name="maritalStatus" value="widowed" /> Widowed</label>
        </div>
      </div>
    </div>

    <!-- =================== S6: EMERGENCY CONTACT =================== -->
    <div class="form-section" id="s6" data-label="Emergency Contact">
      <div class="section-header">
        <div class="section-icon">🚨</div>
        <h2>Emergency Contact</h2>
        <p>Who should we call if we can't reach you?</p>
      </div>
      <div class="field-group">
        <label class="field-label" for="emg-name">Full Name <span class="req">*</span></label>
        <input class="field-input" type="text" id="emg-name" name="emergencyContactName" required />
        <div class="field-error" id="err-emg-name">Please enter an emergency contact name.</div>
      </div>
      <div class="field-row-2">
        <div class="field-group">
          <label class="field-label" for="emg-rel">Relationship <span class="req">*</span></label>
          <input class="field-input" type="text" id="emg-rel" name="emergencyContactRelationship" placeholder="e.g. Mother, Spouse" required />
          <div class="field-error" id="err-emg-rel">Please enter their relationship.</div>
        </div>
        <div class="field-group">
          <label class="field-label" for="emg-phone">Phone Number <span class="req">*</span></label>
          <input class="field-input" type="tel" id="emg-phone" name="emergencyContactPhone" required />
          <div class="field-error" id="err-emg-phone">Please enter their phone number.</div>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Address</label>
        <input class="field-input" type="text" name="emergencyContactAddress" />
        <label class="checkbox-pill" style="margin-top:5px;"><input type="checkbox" name="emgAddressUnknown" /> Address is unknown</label>
      </div>
    </div>

    <!-- =================== S7: MEDICAL & INSURANCE =================== -->
    <div class="form-section" id="s7" data-label="Medical & Insurance">
      <div class="section-header">
        <div class="section-icon">🏥</div>
        <h2>Medical &amp; Insurance Info</h2>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Medicaid / MA #</label><input class="field-input" type="text" name="maNumber" /></div>
        <div class="field-group"><label class="field-label">MCO Name</label><input class="field-input" type="text" name="mcoName" placeholder="e.g. Careleon, Optum" /></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label">Other Primary Insurance #</label><input class="field-input" type="text" name="otherInsuranceNumber" /></div>
        <div class="field-group"><label class="field-label">Group #</label><input class="field-input" type="text" name="groupNumber" /></div>
      </div>
      <div class="field-group"><label class="field-label">Current Medical Issues</label><textarea class="field-input" name="medicalIssues" rows="2"></textarea></div>
      <div class="field-group"><label class="field-label">Current Mental Health Diagnosis</label><textarea class="field-input" name="mentalHealthDiagnosis" rows="2"></textarea></div>
      <div class="field-group"><label class="field-label">Allergies</label><input class="field-input" type="text" name="allergies" placeholder="Type 'None' if none" /></div>
    </div>

    <!-- =================== S8: PCP =================== -->
    <div class="form-section" id="s8" data-label="Primary Care Physician">
      <div class="section-header">
        <div class="section-icon">👨‍⚕️</div>
        <h2>Primary Care Physician</h2>
        <p>Your regular doctor. Skip if you don't have one.</p>
      </div>
      <div class="field-group">
        <label class="field-label">Do you have a PCP?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="hasPCP" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="hasPCP" value="yes" /> Yes</label></div>
      </div>
      <div id="pcp-fields" style="display:none;">
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">Doctor's Name</label><input class="field-input" type="text" name="pcpName" /></div>
          <div class="field-group"><label class="field-label">Doctor's Phone</label><input class="field-input" type="tel" name="pcpPhone" /></div>
        </div>
        <div class="field-group"><label class="field-label">Doctor's Address</label><input class="field-input" type="text" name="pcpStreet" /></div>
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">City</label><input class="field-input" type="text" name="pcpCity" /></div>
          <div class="field-group"><label class="field-label">Date of Last Exam</label><input class="field-input" type="date" name="pcpLastExam" /></div>
        </div>
      </div>
      <label class="checkbox-pill" style="margin-top: var(--spacing-3);"><input type="checkbox" name="noPCPAcknowledge" /> I don't have a PCP and will notify WEL when I find one</label>
    </div>

    <!-- =================== S9: MEDICATIONS =================== -->
    <div class="form-section" id="s9" data-label="Medications">
      <div class="section-header">
        <div class="section-icon">💊</div>
        <h2>Current Medications</h2>
        <p>List all prescriptions and over-the-counter medicines you're taking.</p>
      </div>
      <div class="med-table-wrap">
        <table class="med-table">
          <thead><tr><th>Medication</th><th>Dose / How Often</th><th>Prescribing Doctor</th><th>Start Date</th><th></th></tr></thead>
          <tbody id="med-body">
            <tr><td><input type="text" name="meds[0][name]" /></td><td><input type="text" name="meds[0][dose]" /></td><td><input type="text" name="meds[0][prescriber]" /></td><td><input type="date" name="meds[0][startDate]" /></td><td></td></tr>
          </tbody>
        </table>
      </div>
      <button type="button" class="btn-add-row" id="add-med">+ Add another medication</button>
      <label class="checkbox-pill" style="margin-top: 12px;"><input type="checkbox" name="noMeds" /> I am not currently taking any medications</label>
    </div>

    <!-- =================== S10: PRIMARY DRUG USE =================== -->
    <div class="form-section sud-section" id="s10" data-label="Substance Use History">
      <div class="section-header">
        <div class="section-icon">💬</div>
        <h2>Substance Use History</h2>
        <p>These questions help us build the best treatment plan for you. There is no judgment here.</p>
        <div class="sud-badge">SUD Section</div>
      </div>
      <div class="field-group">
        <label class="field-label">Are you currently using Methadone, Suboxone, or MAT?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="isOnMAT" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="isOnMAT" value="yes" /> Yes</label><label class="radio-pill"><input type="radio" name="isOnMAT" value="na" /> N/A</label></div>
        <div id="mat-dose" style="display:none; margin-top:8px;"><label class="field-label">Current Suboxone dose: <input class="field-input" type="text" name="matDose" placeholder="e.g. 8mg" style="display:inline-block; width:120px; margin-left:8px;" /> mg</label></div>
      </div>
      <div class="field-group">
        <label class="field-label">Number of overdoses in the last year:</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="overdosesLastYear" value="0" checked /> None</label><label class="radio-pill"><input type="radio" name="overdosesLastYear" value="1" /> 1</label><label class="radio-pill"><input type="radio" name="overdosesLastYear" value="2+" /> 2 or more</label></div>
      </div>
      <div class="field-row-2">
        <div class="field-group"><label class="field-label"># of prior treatment attempts:</label><input class="field-input" type="number" name="priorTreatmentAttempts" min="0" placeholder="0" /></div>
        <div class="field-group"><label class="field-label">Longest sobriety period:</label><input class="field-input" type="text" name="longestSobriety" placeholder="e.g. 6 months, 2 years, never" /></div>
      </div>
      <div class="field-group">
        <label class="field-label">Do you use tobacco or nicotine?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="tobaccoUse" value="no" /> No</label><label class="radio-pill"><input type="radio" name="tobaccoUse" value="yes" /> Yes — type: <input type="text" name="tobaccoType" style="width:140px;border:none;border-bottom:1px solid #cbd5e1;background:transparent;font-size:0.9rem;margin-left:4px;" /></label></div>
      </div>
      <div class="field-group">
        <label class="field-label">Have you ever overdosed and then used substances within 24 hours?</label>
        <div class="radio-row flex-wrap">
          <label class="radio-pill"><input type="radio" name="usedAfterOD" value="na" checked /> Never overdosed</label>
          <label class="radio-pill"><input type="radio" name="usedAfterOD" value="no" /> Overdosed — did NOT use within 24 hrs</label>
          <label class="radio-pill"><input type="radio" name="usedAfterOD" value="yes" /> Yes, used within 24 hrs after OD</label>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Do you have any issues with gambling?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="gamblingIssues" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="gamblingIssues" value="yes" /> Yes</label></div>
      </div>
    </div>

    <!-- =================== S11: DRUG TABLE =================== -->
    <div class="form-section sud-section" id="s11" data-label="Drugs Used">
      <div class="section-header">
        <div class="section-icon">📊</div>
        <h2>Primary Drugs Used</h2>
        <p>List the main substances you use. Add as many rows as you need.</p>
        <div class="sud-badge">SUD Section</div>
      </div>
      <div class="med-table-wrap">
        <table class="med-table">
          <thead><tr><th>Drug</th><th>Severity</th><th>Route</th><th>Age of 1st Use</th><th>Last Date Used</th><th></th></tr></thead>
          <tbody id="drug-body">
            <tr>
              <td><input type="text" name="drugs[0][name]" placeholder="e.g. Alcohol" /></td>
              <td><select name="drugs[0][severity]"><option value="">Select...</option><option>Mild</option><option>Moderate</option><option>Severe</option></select></td>
              <td><select name="drugs[0][route]"><option value="">Select...</option><option>Inject</option><option>Smoke</option><option>Snort</option><option>Oral</option><option>Other</option></select></td>
              <td><input type="number" name="drugs[0][ageFirst]" min="1" max="100" placeholder="Age" /></td>
              <td><input type="date" name="drugs[0][lastUsed]" /></td>
              <td></td>
            </tr>
          </tbody>
        </table>
      </div>
      <button type="button" class="btn-add-row" id="add-drug">+ Add another drug</button>
    </div>

    <!-- =================== S12: LEGAL =================== -->
    <div class="form-section sud-section" id="s12" data-label="Legal History">
      <div class="section-header">
        <div class="section-icon">⚖️</div>
        <h2>Legal History</h2>
        <p>This information is confidential and only used to coordinate your care.</p>
        <div class="sud-badge">SUD Section</div>
      </div>
      <div class="field-group">
        <label class="field-label">Have you ever been incarcerated?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="everIncarcerated" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="everIncarcerated" value="yes" /> Yes</label></div>
        <div id="incarceration-when" style="display:none; margin-top:10px;">
          <p class="field-hint">When?</p>
          <div class="checkbox-grid" style="margin-top:4px;">
            <label class="checkbox-pill"><input type="checkbox" name="incarcerationWhen[]" value="30d" /> Within last 30 days</label>
            <label class="checkbox-pill"><input type="checkbox" name="incarcerationWhen[]" value="60d" /> Within last 60 days</label>
            <label class="checkbox-pill"><input type="checkbox" name="incarcerationWhen[]" value="12mo" /> Within last 12 months</label>
            <label class="checkbox-pill"><input type="checkbox" name="incarcerationWhen[]" value="1yr+" /> More than 1 year ago</label>
          </div>
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Did you use substances while incarcerated?</label>
        <div class="radio-row"><label class="radio-pill"><input type="radio" name="usedWhileIncarcerated" value="no" checked /> No</label><label class="radio-pill"><input type="radio" name="usedWhileIncarcerated" value="yes" /> Yes</label><label class="radio-pill"><input type="radio" name="usedWhileIncarcerated" value="na" /> N/A</label></div>
      </div>
      <div class="field-group">
        <label class="field-label">Are you currently on any of the following?</label>
        <div class="checkbox-grid">
          <label class="checkbox-pill"><input type="checkbox" name="legal_status[]" value="home_detention" /> Home Detention</label>
          <label class="checkbox-pill"><input type="checkbox" name="legal_status[]" value="parole" id="parole-check" /> Parole</label>
          <label class="checkbox-pill"><input type="checkbox" name="legal_status[]" value="probation" id="probation-check" /> Probation</label>
        </div>
      </div>
      <div id="agent-section" style="display:none;">
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">Start Date</label><input class="field-input" type="date" name="legalStartDate" /></div>
          <div class="field-group"><label class="field-label">End Date</label><input class="field-input" type="date" name="legalEndDate" /></div>
        </div>
        <div class="field-row-2">
          <div class="field-group"><label class="field-label">Agent/Officer Name</label><input class="field-input" type="text" name="agentName" /></div>
          <div class="field-group"><label class="field-label">Agent Phone</label><input class="field-input" type="tel" name="agentPhone" /></div>
        </div>
        <div class="field-row-2">
