    <!-- SUCCESS -->
    <div class="form-section success-slide" id="s-success" style="display:none; text-align:center; padding: 60px 0;">
      <div class="success-ring"><svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
      <h2 style="margin: 20px 0 10px;">Your form has been received.</h2>
      <p style="color:var(--muted); max-width:480px; margin-inline:auto; line-height:1.7;">Thank you for taking this step. We'll review your intake and reach out within <strong>1&ndash;2 business days</strong>. Questions? Call <a href="tel:443-826-2770">443-826-2770</a>.</p>
      <p style="color:var(--muted); max-width:480px; margin-inline:auto; line-height:1.7; font-size:0.875rem; margin-top:1rem;">Staff downloads are available for 90 days after submission. After 90 days, downloadable files are automatically removed to protect your privacy and manage secure storage.</p>
