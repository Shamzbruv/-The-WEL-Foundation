---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Contact Us - The WEL Foundation">
  <div class="container" style="padding: var(--spacing-8) 0;">
    <header class="reveal-on-scroll" style="margin-bottom: var(--spacing-8); text-align:center; max-width: 800px; margin-inline: auto;">
      <h1 style="font-size: 3rem; color: var(--color-primary-blue); margin-bottom: var(--spacing-3);">Contact Our Office</h1>
      <p style="font-size: 1.15rem; color: var(--color-text-muted); line-height: 1.6;">
        Have a general inquiry or need assistance navigating our programs? Reach out securely below. If you are experiencing a medical or psychological emergency, please call <strong>911</strong> or the National Suicide Prevention Lifeline at <strong>988</strong> immediately.
      </p>
    </header>

    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: var(--spacing-8);">
      <div class="reveal-on-scroll stagger-1">
        <h2 style="font-size: 1.8rem; color: var(--color-primary-light-blue); margin-bottom: var(--spacing-4);">Visiting The WEL Foundation</h2>
        
        <div style="margin-bottom: var(--spacing-6);">
          <h3 style="font-size: 1.2rem; margin-bottom: var(--spacing-1);">Baltimore Headquarters</h3>
          <p style="color: var(--color-text-muted); line-height: 1.6;">
            5858 Belair Rd<br/>
            Baltimore, MD 21206<br/>
            <em>On-site parking is available in the rear lot. Our facility is fully wheelchair accessible.</em>
          </p>
        </div>

        <div style="margin-bottom: var(--spacing-6);">
          <h3 style="font-size: 1.2rem; margin-bottom: var(--spacing-1);">Direct Lines</h3>
          <p style="color: var(--color-text-muted); line-height: 1.6;">
            <strong>Phone:</strong> <a href="tel:443-826-2770" style="text-decoration: none;">443-826-2770</a><br/>
            <strong>Email:</strong> <a href="mailto:info@weempowerleadership.com" style="text-decoration: none;">info@weempowerleadership.com</a>
          </p>
        </div>

        <div>
          <h3 style="font-size: 1.2rem; margin-bottom: var(--spacing-1);">Office Hours</h3>
          <p style="color: var(--color-text-muted); line-height: 1.6;">
            Monday &ndash; Friday: 9:00 AM &ndash; 6:00 PM<br/>
            Saturday: By appointment only<br/>
            Sunday: Closed
          </p>
        </div>
      </div>

      <div class="reveal-on-scroll stagger-2">
        <div class="card">
          <h3 style="font-size: 1.4rem; margin-bottom: var(--spacing-4);">Secure Inquiry Form</h3>
          <p style="font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: var(--spacing-4);">To become a client, please use our <a href="/intake/start/">Intake form</a>. Use this form for general questions.</p>
          <form id="contact-form">
            <div class="form-group" style="margin-bottom: var(--spacing-3);">
              <label for="contact-name" style="font-size: 0.9rem; margin-bottom: var(--spacing-1);">Full Name</label>
              <input type="text" id="contact-name" name="name" required style="width: 100%; border-radius: var(--radius-sm); border: 1px solid var(--color-border);" />
            </div>
            <div class="form-group" style="margin-bottom: var(--spacing-3);">
              <label for="contact-email" style="font-size: 0.9rem; margin-bottom: var(--spacing-1);">Email Address</label>
              <input type="email" id="contact-email" name="email" required style="width: 100%; border-radius: var(--radius-sm); border: 1px solid var(--color-border);" />
            </div>
            <div class="form-group" style="margin-bottom: var(--spacing-4);">
              <label for="contact-message" style="font-size: 0.9rem; margin-bottom: var(--spacing-1);">Message</label>
              <textarea id="contact-message" name="message" rows="5" required style="width: 100%; border-radius: var(--radius-sm); border: 1px solid var(--color-border);"></textarea>
            </div>
            <div id="contact-error" style="color:var(--color-error); font-size: 0.9rem; margin-bottom:1rem; display:none;"></div>
            <div id="contact-success" style="color:#2E7D32; font-size: 0.9rem; font-weight:bold; margin-bottom:1rem; display:none;">Your message has been sent successfully. Our team will review and respond shortly.</div>
            <button class="btn" type="submit" id="contact-submit" style="width: 100%;">Send Secure Message</button>
          </form>
        </div>
      </div>
    </div>
    
    <script>
    // @ts-nocheck
      document.getElementById('contact-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('contact-submit');
        const errBox = document.getElementById('contact-error');
        const sucBox = document.getElementById('contact-success');
        btn.disabled = true;
        btn.innerText = 'Sending...';
        errBox.style.display = 'none';
        sucBox.style.display = 'none';
        
        try {
           const formData = new FormData(e.target);
           const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
           
           const res = await fetch(`${supabaseUrl}/functions/v1/contact-submit`, {
              method: 'POST',
              body: formData
           });
           
           if(!res.ok) throw new Error("Failed to submit contact form.");
           
           sucBox.style.display = 'block';
           e.target.reset();
        } catch(err) {
           errBox.style.display = 'block';
           errBox.innerText = err.message;
        } finally {
           btn.disabled = false;
           btn.innerText = 'Send Secure Message';
        }
      });
    </script>
  </div>
</Layout>
